<Window x:Class="ScreenMemory.AI.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ScreenMemory AI"
        Icon="pack://application:,,,/Assets/AppIcon.ico"
        Height="780"
        Width="1240"
        MinHeight="620"
        MinWidth="960"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="CanResize"
        FontFamily="Inter, Segoe UI Variable Display, Segoe UI Variable, Segoe UI, sans-serif"
        Background="#0B0C0E"
        SnapsToDevicePixels="True"
        UseLayoutRounding="True">

    <Window.Resources>

        <!-- ═══════════════════════════════════════════════════════
             SOPHISTICATED COLOR PALETTE
        ═══════════════════════════════════════════════════════ -->
        
        <!-- Core Backgrounds -->
        <SolidColorBrush x:Key="BackgroundDeep"       Color="#0B0C0E"/>
        <SolidColorBrush x:Key="BackgroundPrimary"    Color="#0E0E10"/>
        <SolidColorBrush x:Key="BackgroundSecondary"  Color="#121317"/>
        <SolidColorBrush x:Key="BackgroundTertiary"   Color="#1A1B1F"/>
        <SolidColorBrush x:Key="BackgroundElevated"   Color="#1E1F24"/>
        <SolidColorBrush x:Key="BackgroundHover"      Color="#292A2E"/>
        <SolidColorBrush x:Key="SurfaceBright"        Color="#38393D"/>
        <SolidColorBrush x:Key="SurfaceGlass"         Color="#B216171B"/>
        
        <!-- Borders -->
        <SolidColorBrush x:Key="BorderSubtle"        Color="#14FFFFFF"/>
        <SolidColorBrush x:Key="BorderDefault"       Color="#26FFFFFF"/>
        <SolidColorBrush x:Key="BorderEmphasis"       Color="#494454"/>
        
        <!-- Neon Purple Accent System -->
        <SolidColorBrush x:Key="AccentPrimary"        Color="#8B5CF6"/>
        <SolidColorBrush x:Key="AccentHover"          Color="#A78BFA"/>
        <SolidColorBrush x:Key="AccentPressed"        Color="#6D3BD7"/>
        <SolidColorBrush x:Key="AccentSubtle"         Color="#1A8B5CF6"/>
        <SolidColorBrush x:Key="AccentMuted"          Color="#5B4A8C"/>
        <SolidColorBrush x:Key="AccentGlow"           Color="#D0BCFF"/>
        <SolidColorBrush x:Key="AccentGlowIntense"    Color="#E9DDFF"/>
        <SolidColorBrush x:Key="AccentSecondary"      Color="#3B82F6"/>
        
        <!-- Gradient for Glow Effects -->
        <LinearGradientBrush x:Key="AccentGlowGradient" StartPoint="0,0" EndPoint="1,0">
            <GradientStop Color="#8B5CF6" Offset="0"/>
            <GradientStop Color="#3B82F6" Offset="1"/>
        </LinearGradientBrush>
        
        <LinearGradientBrush x:Key="AccentVerticalGlow" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#8B5CF6" Offset="0"/>
            <GradientStop Color="#6366F1" Offset="1"/>
        </LinearGradientBrush>
        
        <!-- Status Colors -->
        <SolidColorBrush x:Key="StatusSuccess"        Color="#10B981"/>
        <SolidColorBrush x:Key="StatusSuccessGlow"   Color="#34D399"/>
        <SolidColorBrush x:Key="StatusSuccessSubtle"  Color="#0D2E22"/>
        <SolidColorBrush x:Key="StatusInfo"          Color="#3B82F6"/>
        <SolidColorBrush x:Key="StatusInfoSubtle"    Color="#0D1E3D"/>
        
        <!-- Text Colors -->
        <SolidColorBrush x:Key="TextPrimary"          Color="#FFFFFF"/>
        <SolidColorBrush x:Key="TextSecondary"        Color="#CBC3D7"/>
        <SolidColorBrush x:Key="TextTertiary"        Color="#A1A1AA"/>
        <SolidColorBrush x:Key="TextMuted"            Color="#6F687A"/>

        <!-- ═══════════════════════════════════════════════════════
             DROP SHADOW EFFECTS
        ═══════════════════════════════════════════════════════ -->
        
        <DropShadowEffect x:Key="NeonGlowShadow"
                          Color="#8B5CF6"
                          BlurRadius="20"
                          ShadowDepth="0"
                          Opacity="0.4"/>
        
        <DropShadowEffect x:Key="CardShadow"
                          Color="#000000"
                          BlurRadius="26"
                          ShadowDepth="0"
                          Opacity="0.36"/>
        
        <DropShadowEffect x:Key="SubtleShadow"
                          Color="#000000"
                          BlurRadius="18"
                          ShadowDepth="0"
                          Opacity="0.26"/>

        <!-- ═══════════════════════════════════════════════════════
             TYPOGRAPHY
        ═══════════════════════════════════════════════════════ -->
        
        <Style x:Key="TypographyTitleLarge" TargetType="TextBlock">
            <Setter Property="FontSize" Value="24"/>
            <Setter Property="FontWeight" Value="600"/>
            <Setter Property="FontFamily" Value="Inter, Segoe UI Variable Display, Segoe UI, sans-serif"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
        </Style>
        
        <Style x:Key="TypographyTitleMedium" TargetType="TextBlock">
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="600"/>
            <Setter Property="FontFamily" Value="Inter, Segoe UI Variable Display, Segoe UI, sans-serif"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
        </Style>
        
        <Style x:Key="TypographyTitleSmall" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="600"/>
            <Setter Property="FontFamily" Value="Inter, Segoe UI Variable Display, Segoe UI, sans-serif"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
        </Style>
        
        <Style x:Key="TypographyBodyLarge" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="400"/>
            <Setter Property="FontFamily" Value="Inter, Segoe UI Variable Display, Segoe UI, sans-serif"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
        </Style>
        
        <Style x:Key="TypographyBodyDefault" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="400"/>
            <Setter Property="FontFamily" Value="Inter, Segoe UI Variable Display, Segoe UI, sans-serif"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
        </Style>
        
        <Style x:Key="TypographyBodySmall" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="400"/>
            <Setter Property="FontFamily" Value="Inter, Segoe UI Variable Display, Segoe UI, sans-serif"/>
            <Setter Property="Foreground" Value="{StaticResource TextTertiary}"/>
        </Style>
        
        <Style x:Key="TypographyLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="FontWeight" Value="600"/>
            <Setter Property="FontFamily" Value="Inter, Segoe UI Variable Display, Segoe UI, sans-serif"/>
            <Setter Property="Foreground" Value="{StaticResource TextMuted}"/>
        </Style>

        <!-- ═══════════════════════════════════════════════════════
             BUTTON STYLES
        ═══════════════════════════════════════════════════════ -->

        <Style x:Key="ButtonPrimary" TargetType="Button">
            <Setter Property="Background">
                <Setter.Value>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#8B5CF6" Offset="0"/>
                        <GradientStop Color="#3B82F6" Offset="1"/>
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="600"/>
            <Setter Property="FontFamily" Value="Inter, Segoe UI Variable Display, Segoe UI, sans-serif"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="12"
                                Padding="{TemplateBinding Padding}"
                                Effect="{StaticResource SubtleShadow}">
                            <Grid>
                                <Border Height="1"
                                        VerticalAlignment="Top"
                                        CornerRadius="12,12,0,0"
                                        Background="#45FFFFFF"/>
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background">
                                    <Setter.Value>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#A78BFA" Offset="0"/>
                                            <GradientStop Color="#3B82F6" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Setter.Value>
                                </Setter>
                                <Setter TargetName="border" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect Color="#8B5CF6" BlurRadius="15" ShadowDepth="0" Opacity="0.4"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background">
                                    <Setter.Value>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#7C3AED" Offset="0"/>
                                            <GradientStop Color="#3B82F6" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ButtonSecondary" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource BackgroundElevated}"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderDefault}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="500"/>
            <Setter Property="FontFamily" Value="Inter, Segoe UI Variable Display, Segoe UI, sans-serif"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="14,9"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{StaticResource BackgroundHover}"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource BorderEmphasis}"/>
                                <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{StaticResource BackgroundTertiary}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SearchModeButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TextTertiary}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="11.5"/>
            <Setter Property="FontWeight" Value="600"/>
            <Setter Property="FontFamily" Value="Inter, Segoe UI Variable Display, Segoe UI, sans-serif"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="MinWidth" Value="76"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="9"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#20232D"/>
                                <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
                            </Trigger>
                            <Trigger Property="Tag" Value="Selected">
                                <Setter TargetName="border" Property="Background" Value="#2A1C4A"/>
                                <Setter Property="Foreground" Value="{StaticResource AccentGlow}"/>
                                <Setter TargetName="border" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect Color="#8B5CF6" BlurRadius="10" ShadowDepth="0" Opacity="0.28"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="{StaticResource TextMuted}"/>
                                <Setter TargetName="border" Property="Opacity" Value="0.45"/>
                                <Setter Property="Cursor" Value="Arrow"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ButtonWindowControl" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TextTertiary}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="36"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets, Segoe UI Symbol, sans-serif"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{StaticResource BackgroundHover}"/>
                                <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{StaticResource BackgroundTertiary}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ButtonWindowControlClose" TargetType="Button" BasedOn="{StaticResource ButtonWindowControl}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#DC2626"/>
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#B91C1C"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ButtonIcon" TargetType="Button" BasedOn="{StaticResource ButtonWindowControl}">
            <Setter Property="Width" Value="30"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="FontSize" Value="10"/>
        </Style>

        <Style x:Key="ButtonNav" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TextTertiary}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="Margin" Value="0,1"/>
            <Setter Property="FontSize" Value="12.5"/>
            <Setter Property="FontWeight" Value="500"/>
            <Setter Property="FontFamily" Value="Inter, Segoe UI Variable Display, Segoe UI, sans-serif"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="12"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{StaticResource BackgroundHover}"/>
                                <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{StaticResource BackgroundTertiary}"/>
                                <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ToggleSwitchStyle" TargetType="CheckBox">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Border x:Name="SwitchTrack"
                                Width="38"
                                Height="22"
                                CornerRadius="11"
                                Background="{StaticResource BackgroundTertiary}"
                                BorderBrush="{StaticResource BorderDefault}"
                                BorderThickness="1">
                            <Ellipse x:Name="SwitchKnob"
                                     Width="16"
                                     Height="16"
                                     Fill="{StaticResource TextSecondary}"
                                     HorizontalAlignment="Left"
                                     Margin="3,0,0,0"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="SwitchTrack" Property="Background" Value="{StaticResource AccentPrimary}"/>
                                <Setter TargetName="SwitchTrack" Property="BorderBrush" Value="{StaticResource AccentPrimary}"/>
                                <Setter TargetName="SwitchKnob" Property="Fill" Value="#FFFFFF"/>
                                <Setter TargetName="SwitchKnob" Property="HorizontalAlignment" Value="Right"/>
                                <Setter TargetName="SwitchKnob" Property="Margin" Value="0,0,3,0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="FolderListItem" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Bd"
                                Background="{StaticResource BackgroundTertiary}"
                                BorderBrush="{StaticResource BorderSubtle}"
                                BorderThickness="1"
                                CornerRadius="10"
                                Padding="14,12">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0"
                                        Width="4"
                                        Height="36"
                                        CornerRadius="2"
                                        Background="{StaticResource AccentPrimary}"
                                        Margin="0,0,14,0"
                                        Opacity="0.7">
                                    <Border.Effect>
                                        <DropShadowEffect Color="#8B5CF6" BlurRadius="8" ShadowDepth="0" Opacity="0.5"/>
                                    </Border.Effect>
                                </Border>

                                <Border Grid.Column="1"
                                        Width="38"
                                        Height="38"
                                        CornerRadius="10"
                                        Background="{StaticResource BackgroundSecondary}"
                                        BorderBrush="{StaticResource BorderDefault}"
                                        BorderThickness="1"
                                        VerticalAlignment="Center">
                                    <Viewbox Width="18" Height="18">
                                        <Path Data="M20 6h-8l-2-2H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V8c0-1.1-.9-2-2-2zm0 12H4V6h5.17l2 2H20v10z"
                                              Fill="{StaticResource AccentGlow}"
                                              Stretch="Uniform"/>
                                    </Viewbox>
                                </Border>

                                <TextBlock Grid.Column="2"
                                           Text="{Binding}"
                                           FontSize="12.5"
                                           FontWeight="500"
                                           Foreground="{StaticResource TextPrimary}"
                                           TextTrimming="CharacterEllipsis"
                                           ToolTip="{Binding}"
                                           VerticalAlignment="Center"
                                           Margin="12,0,12,0"/>

                                <Button Grid.Column="3"
                                        Content="&#xE711;"
                                        Style="{StaticResource ButtonIcon}"
                                        ToolTip="Remove folder"
                                        Tag="{Binding}"
                                        Click="RemoveSettingsFolderItem_Click"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource BackgroundElevated}"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource BorderDefault}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource AccentSubtle}"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource AccentPrimary}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══════════════════════════════════════════════════════
             INPUT STYLES
        ═══════════════════════════════════════════════════════ -->

        <Style x:Key="InputSearch" TargetType="TextBox">
            <Setter Property="Background" Value="{StaticResource BackgroundTertiary}"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="CaretBrush" Value="{StaticResource AccentPrimary}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderSubtle}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontFamily" Value="Inter, Segoe UI Variable Display, Segoe UI, sans-serif"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="48"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Viewbox Grid.Column="0"
                                         Width="16"
                                         Height="16"
                                         HorizontalAlignment="Center"
                                         VerticalAlignment="Center">
                                    <Path Data="M15.5 14h-.79l-.28-.27a6.5 6.5 0 1 0-.7.7l.27.28v.79l5 4.99L20.49 19l-4.99-5zm-6 0A4.5 4.5 0 1 1 14 9.5 4.5 4.5 0 0 1 9.5 14z" 
                                          Fill="{StaticResource TextMuted}" Stretch="Uniform"/>
                                </Viewbox>
                                <TextBlock x:Name="SearchPlaceholder"
                                           Grid.Column="1"
                                           Text="Search screenshots..."
                                           Foreground="{StaticResource TextMuted}"
                                           FontSize="13"
                                           VerticalAlignment="Center"
                                           Margin="0,0,14,0"
                                           IsHitTestVisible="False"
                                           Visibility="Collapsed"/>
                                <ScrollViewer x:Name="PART_ContentHost"
                                              Grid.Column="1"
                                              Margin="0,0,14,0"
                                              HorizontalAlignment="Stretch"
                                              VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource AccentPrimary}"/>
                                <Setter TargetName="border" Property="Background" Value="{StaticResource BackgroundElevated}"/>
                                <Setter TargetName="border" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect Color="#8B5CF6" BlurRadius="12" ShadowDepth="0" Opacity="0.3"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource BorderDefault}"/>
                            </Trigger>
                            <Trigger Property="Text" Value="">
                                <Setter TargetName="SearchPlaceholder" Property="Visibility" Value="Visible"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══════════════════════════════════════════════════════
             SCROLLBAR STYLE
        ═══════════════════════════════════════════════════════ -->
        
        <Style TargetType="ScrollBar">
            <Setter Property="Width" Value="6"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid>
                            <Track x:Name="PART_Track" IsDirectionReversed="True">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Opacity="0" Height="0"/>
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border Background="{StaticResource BorderDefault}" CornerRadius="3" Margin="1"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Opacity="0" Height="0"/>
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══════════════════════════════════════════════════════
             DATA TEMPLATE
        ═══════════════════════════════════════════════════════ -->
        
        <DataTemplate x:Key="ScreenshotCardTemplate">
            <Border Width="176"
                    Height="154"
                    Margin="0,0,14,16"
                    CornerRadius="12"
                    Cursor="Hand"
                    RenderTransformOrigin="0.5,0.5"
                    Effect="{StaticResource SubtleShadow}"
                    MouseLeftButtonDown="ScreenshotCard_MouseLeftButtonDown">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Background" Value="{StaticResource BackgroundTertiary}"/>
                        <Setter Property="BorderBrush" Value="{StaticResource BorderSubtle}"/>
                        <Setter Property="BorderThickness" Value="1"/>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="BorderBrush" Value="{StaticResource BorderDefault}"/>
                                <Setter Property="Background" Value="{StaticResource BackgroundElevated}"/>
                                <Setter Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="1.02" ScaleY="1.02"/>
                                    </Setter.Value>
                                </Setter>
                                <Setter Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect Color="#000000" BlurRadius="18" ShadowDepth="4" Opacity="0.45"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                <Setter Property="BorderBrush" Value="{StaticResource AccentPrimary}"/>
                                <Setter Property="BorderThickness" Value="1.5"/>
                                <Setter Property="Background" Value="{StaticResource AccentSubtle}"/>
                                <Setter Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect Color="#8B5CF6" BlurRadius="14" ShadowDepth="0" Opacity="0.28"/>
                                    </Setter.Value>
                                </Setter>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="104"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0"
                                Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Top"
                                Margin="0,10,10,0"
                                Panel.ZIndex="4">
                        <Button Width="26"
                                Height="26"
                                Padding="0"
                                Style="{StaticResource ButtonSecondary}"
                                Tag="{Binding}"
                                ToolTip="Add to favourites"
                                Click="FavoriteScreenshot_Click">
                            <TextBlock Text="&#xE734;"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="11">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{StaticResource TextTertiary}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsFavorite}" Value="True">
                                                <Setter Property="Foreground" Value="{StaticResource AccentGlow}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Button>
                    </StackPanel>

                    <Border Grid.Row="0"
                            Background="{StaticResource BackgroundPrimary}"
                            CornerRadius="11,11,0,0"
                            ClipToBounds="True"
                            Margin="5,5,5,0">
                        <Image Source="{Binding ThumbnailPath}"
                               Stretch="UniformToFill"
                               RenderOptions.BitmapScalingMode="HighQuality"
                               VerticalAlignment="Center"/>
                    </Border>

                    <Border Grid.Row="0"
                            Height="28"
                            VerticalAlignment="Bottom"
                            Margin="5,0,5,0"
                            IsHitTestVisible="False">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Color="#00111217" Offset="0"/>
                                <GradientStop Color="#D9111217" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                    </Border>

                    <StackPanel Grid.Row="1"
                                Margin="10,8,10,8">
                        <TextBlock Text="{Binding FileName}"
                                   FontSize="11.5"
                                   FontWeight="600"
                                   Foreground="{StaticResource TextPrimary}"
                                   TextTrimming="CharacterEllipsis"
                                   ToolTip="{Binding FileName}"/>
                        <Grid Margin="0,5,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="{Binding AiCategory}"
                                       FontSize="10.5"
                                       FontWeight="600"
                                       Foreground="{StaticResource AccentGlow}"
                                       TextTrimming="CharacterEllipsis"/>
                            <TextBlock Grid.Column="1"
                                       Text="{Binding ApplicationName}"
                                       FontSize="10"
                                       Foreground="{StaticResource TextMuted}"
                                       TextTrimming="CharacterEllipsis"
                                       MaxWidth="54"
                                       Margin="8,0,0,0"/>
                        </Grid>
                    </StackPanel>
                </Grid>
            </Border>
        </DataTemplate>

    </Window.Resources>

    <!-- ═══════════════════════════════════════════════════════
         ROOT LAYOUT
    ═══════════════════════════════════════════════════════ -->
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition x:Name="PreviewColumn" Width="0"/>
        </Grid.ColumnDefinitions>

        <!-- ╔════════════════════════════════════════════════════╗
             ║                    SIDEBAR                        ║
             ╚════════════════════════════════════════════════════╝ -->
        <Border Grid.Column="0"
                Background="{StaticResource BackgroundSecondary}"
                BorderBrush="{StaticResource BorderSubtle}"
                BorderThickness="0,0,1,0">
            <DockPanel>

                <!-- Brand Header -->
                <Border DockPanel.Dock="Top"
                        Padding="16,16,16,14"
                        BorderBrush="{StaticResource BorderSubtle}"
                        BorderThickness="0,0,0,1">
                    <StackPanel Orientation="Horizontal">
                        <!-- App Icon with Neon Glow -->
                        <Border Width="36" Height="36" CornerRadius="10" ClipToBounds="True"
                                Background="{StaticResource BackgroundTertiary}"
                                BorderBrush="{StaticResource AccentPrimary}"
                                BorderThickness="1.5">
                            <Border.Effect>
                                <DropShadowEffect Color="#8B5CF6" BlurRadius="10" ShadowDepth="0" Opacity="0.5"/>
                            </Border.Effect>
                            <Image Source="pack://application:,,,/Assets/AppIcon.ico"
                                   Stretch="UniformToFill"
                                   Margin="6"/>
                        </Border>
                        <StackPanel Margin="14,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="ScreenMemory"
                                       Style="{StaticResource TypographyTitleSmall}"/>
                            <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
                                <Border Width="6" Height="6" CornerRadius="3" Background="{StaticResource AccentPrimary}" Margin="0,0,6,0">
                                    <Border.Effect>
                                        <DropShadowEffect Color="#8B5CF6" BlurRadius="4" ShadowDepth="0" Opacity="0.6"/>
                                    </Border.Effect>
                                </Border>
                                <TextBlock Text="AI-Powered"
                                           Style="{StaticResource TypographyBodySmall}"
                                           Foreground="{StaticResource AccentGlow}"/>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border DockPanel.Dock="Bottom"
                        Padding="12,12"
                        BorderBrush="{StaticResource BorderSubtle}"
                        BorderThickness="0,1,0,0">
                    <Border BorderBrush="#1A3D2E"
                            BorderThickness="1"
                            CornerRadius="10"
                            Padding="10,8">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#0D2E22" Offset="0"/>
                                <GradientStop Color="#0A1F1A" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="8" Height="8" Margin="0,0,10,0" VerticalAlignment="Center">
                                <Ellipse.Fill>
                                    <RadialGradientBrush>
                                        <GradientStop Color="#10B981" Offset="0"/>
                                        <GradientStop Color="#34D399" Offset="1"/>
                                    </RadialGradientBrush>
                                </Ellipse.Fill>
                                <Ellipse.Effect>
                                    <DropShadowEffect Color="#10B981" BlurRadius="8" ShadowDepth="0" Opacity="0.7"/>
                                </Ellipse.Effect>
                            </Ellipse>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Local Processing Only" FontSize="11" FontWeight="600" Foreground="{StaticResource StatusSuccess}"/>
                                <TextBlock x:Name="StatusText" Text="Ready" FontSize="10" FontWeight="500" Foreground="{StaticResource TextTertiary}" Margin="0,2,0,0"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Border>

                <StackPanel Margin="10,18,10,0">
                    <Button Style="{StaticResource ButtonNav}" Click="Home_Click">
                        <StackPanel Orientation="Horizontal">
                            <Viewbox Width="15" Height="15" Margin="0,0,12,0">
                                <Path Data="M7 2h10a2 2 0 0 1 2 2v16H5V4a2 2 0 0 1 2-2zm2 4v2h6V6H9zm0 4v2h6v-2H9zm0 4v2h4v-2H9z" Fill="{StaticResource AccentGlow}" Stretch="Uniform"/>
                            </Viewbox>
                            <TextBlock Text="Today" FontSize="12" FontWeight="500" Foreground="{StaticResource TextSecondary}"/>
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource ButtonNav}" Click="Recent_Click">
                        <StackPanel Orientation="Horizontal">
                            <Viewbox Width="15" Height="15" Margin="0,0,12,0">
                                <Path Data="M7 2v2H5a2 2 0 0 0-2 2v2h18V6a2 2 0 0 0-2-2h-2V2h-2v2H9V2H7zm14 8H3v10a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V10z" Fill="{StaticResource TextTertiary}" Stretch="Uniform"/>
                            </Viewbox>
                            <TextBlock Text="Recents" FontSize="12" FontWeight="500" Foreground="{StaticResource TextTertiary}"/>
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource ButtonNav}" Click="Favorites_Click">
                        <StackPanel Orientation="Horizontal">
                            <Viewbox Width="15" Height="15" Margin="0,0,12,0">
                                <Path Data="M12 2l2.9 6.1 6.6.9-4.8 4.7 1.2 6.6L12 17.1l-5.9 3.2 1.2-6.6L2.5 9l6.6-.9L12 2z" Fill="{StaticResource TextTertiary}" Stretch="Uniform"/>
                            </Viewbox>
                            <TextBlock Text="Favourites" FontSize="12" FontWeight="500" Foreground="{StaticResource TextTertiary}"/>
                        </StackPanel>
                    </Button>

                    <Border Height="1" Background="{StaticResource BorderSubtle}" Margin="10,12"/>

                    <Button Style="{StaticResource ButtonNav}" Click="License_Click">
                        <StackPanel Orientation="Horizontal">
                            <Viewbox Width="15" Height="15" Margin="0,0,12,0">
                                <Path Data="M12 2l7 4v6c0 4.4-2.8 8.4-7 10-4.2-1.6-7-5.6-7-10V6l7-4zm0 2.3L7 7.1V12c0 3.2 1.9 6.2 5 7.6 3.1-1.4 5-4.4 5-7.6V7.1l-5-2.8zm-1 4.7h2v5h-2V9zm0 6h2v2h-2v-2z" Fill="{StaticResource TextTertiary}" Stretch="Uniform"/>
                            </Viewbox>
                            <TextBlock Text="License" FontSize="12" FontWeight="500" Foreground="{StaticResource TextTertiary}"/>
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource ButtonNav}" Click="Settings_Click">
                        <StackPanel Orientation="Horizontal">
                            <Viewbox Width="15" Height="15" Margin="0,0,12,0">
                                <Path Data="M19.4 13.5c.1-.5.1-1 .1-1.5s0-1-.1-1.5l2-1.5-2-3.5-2.4 1a7.7 7.7 0 0 0-2.6-1.5L14 2h-4l-.4 2.5A7.7 7.7 0 0 0 7 6L4.6 5l-2 3.5 2 1.5c-.1.5-.1 1-.1 1.5s0 1 .1 1.5l-2 1.5 2 3.5L7 18a7.7 7.7 0 0 0 2.6 1.5L10 22h4l.4-2.5A7.7 7.7 0 0 0 17 18l2.4 1 2-3.5-2-1.5zM12 15.5A3.5 3.5 0 1 1 12 8a3.5 3.5 0 0 1 0 7.5z" Fill="{StaticResource TextTertiary}" Stretch="Uniform"/>
                            </Viewbox>
                            <TextBlock Text="Settings" FontSize="12" FontWeight="500" Foreground="{StaticResource TextTertiary}"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- ╔════════════════════════════════════════════════════╗
             ║               MAIN CONTENT AREA                  ║
             ╚════════════════════════════════════════════════════╝ -->
        <DockPanel Grid.Column="1" Background="{StaticResource BackgroundPrimary}">

            <!-- Title Bar -->
            <Border DockPanel.Dock="Top"
                    Background="{StaticResource BackgroundSecondary}"
                    BorderBrush="{StaticResource BorderSubtle}"
                    BorderThickness="0,0,0,1"
                    Padding="20,12"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBox x:Name="SearchBox"
                              Grid.Column="0"
                              MinWidth="360"
                              Margin="0,0,12,0"
                              Style="{StaticResource InputSearch}"
                              TextChanged="SearchBox_TextChanged"
                              GotKeyboardFocus="SearchBox_GotKeyboardFocus"
                              PreviewMouseLeftButtonDown="SearchBox_PreviewMouseLeftButtonDown"
                              ToolTip="Search screenshots... (e.g., invoice, error, code)"/>

                    <Border Grid.Column="1"
                            Width="168"
                            Height="38"
                            Padding="3"
                            CornerRadius="11"
                            Background="#15161D"
                            BorderBrush="{StaticResource BorderDefault}"
                            BorderThickness="1"
                            VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center">
                            <Button x:Name="KeywordSearchModeButton"
                                    Content="Keyword"
                                    Style="{StaticResource SearchModeButton}"
                                    Click="SearchModeKeyword_Click"
                                    ToolTip="Search filename, OCR text, and metadata"/>
                            <Button x:Name="AiSearchModeButton"
                                    Content="AI"
                                    Style="{StaticResource SearchModeButton}"
                                    Margin="4,0,0,0"
                                    Click="SearchModeAi_Click"
                                    ToolTip="Use AI semantic search"/>
                        </StackPanel>
                    </Border>

                    <Grid Grid.Column="2"
                          Margin="12,0,0,0"
                          VerticalAlignment="Center">
                        <TextBlock x:Name="HeaderLicensePlanText"
                                   Text="Free"
                                   Visibility="Collapsed"/>
                        <TextBlock x:Name="HeaderLicenseUsageText"
                                   Text="0/200"
                                   Visibility="Collapsed"/>
                        <Button x:Name="HeaderUpgradeLicenseButton"
                                Style="{StaticResource ButtonPrimary}"
                                Height="34"
                                Padding="12,0"
                                Click="UpgradeLicense_Click"
                                ToolTip="Upgrade license">
                            <StackPanel Orientation="Horizontal">
                                <Viewbox Width="14" Height="14" Margin="0,0,7,0">
                                    <Path Data="M12 2l2.8 5.7 6.2.9-4.5 4.4 1.1 6.2L12 16.2 6.4 19.2 7.5 13 3 8.6l6.2-.9L12 2z"
                                          Fill="#FFFFFF"
                                          Stretch="Uniform"/>
                                </Viewbox>
                                <TextBlock Text="Upgrade" FontWeight="700"/>
                            </StackPanel>
                        </Button>
                    </Grid>

                    <StackPanel Grid.Column="3" Orientation="Horizontal" Margin="14,0,0,0" VerticalAlignment="Center">
                        <Button Content="&#xE921;" Style="{StaticResource ButtonWindowControl}" Click="WindowMinimize_Click" ToolTip="Minimize"/>
                        <Button Content="&#xE922;" Style="{StaticResource ButtonWindowControl}" Click="WindowMaximizeRestore_Click" ToolTip="Maximize" Margin="3,0,0,0"/>
                        <Button Content="&#xE8BB;" Style="{StaticResource ButtonWindowControlClose}" Click="WindowClose_Click" ToolTip="Close" Margin="3,0,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Scrollable Content Area -->
            <ScrollViewer x:Name="MainContentScrollViewer"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Padding="28,24,24,24"
                          Background="{StaticResource BackgroundPrimary}">
                <Grid>

                    <!-- ══════════════════════════════════════════════
                         HOME DASHBOARD
                    ══════════════════════════════════════════════ -->
                    <StackPanel x:Name="HomeDashboardPanel">

                        <!-- Page Header -->
                        <Grid Margin="0,0,0,20">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Your Screenshot Memory"
                                           Style="{StaticResource TypographyTitleLarge}"/>
                                <TextBlock Text="Search, browse, and rediscover everything you've captured."
                                           Style="{StaticResource TypographyBodyLarge}"
                                           Margin="0,4,0,0"/>
                            </StackPanel>
                        </Grid>

                        <!-- STATS STRIP with Neon Accents -->
                        <Border BorderBrush="{StaticResource BorderSubtle}"
                                BorderThickness="1"
                                CornerRadius="14"
                                Margin="0,0,0,24"
                                Padding="0"
                                Effect="{StaticResource SubtleShadow}">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#18191F" Offset="0"/>
                                    <GradientStop Color="#14151B" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="1"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="1"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <!-- Imported -->
                                <StackPanel Grid.Column="0" Margin="20,16" Orientation="Horizontal">
                                    <Border Width="4" Height="40" CornerRadius="2" 
                                            Background="{StaticResource AccentPrimary}"
                                            Margin="0,0,16,0">
                                        <Border.Effect>
                                            <DropShadowEffect Color="#8B5CF6" BlurRadius="8" ShadowDepth="0" Opacity="0.5"/>
                                        </Border.Effect>
                                    </Border>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock x:Name="ImportedCountText" Text="0" FontSize="22" FontWeight="600" Foreground="{StaticResource TextPrimary}"/>
                                        <TextBlock Text="Imported" Style="{StaticResource TypographyBodySmall}" Margin="0,2,0,0"/>
                                    </StackPanel>
                                </StackPanel>

                                <Border Grid.Column="1" Background="{StaticResource BorderSubtle}"/>

                                <!-- OCR Ready -->
                                <StackPanel Grid.Column="2" Margin="20,16" Orientation="Horizontal">
                                    <Border Width="4" Height="40" CornerRadius="2" 
                                            Background="{StaticResource StatusInfo}"
                                            Margin="0,0,16,0">
                                        <Border.Effect>
                                            <DropShadowEffect Color="#3B82F6" BlurRadius="8" ShadowDepth="0" Opacity="0.5"/>
                                        </Border.Effect>
                                    </Border>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock x:Name="OcrReadyCountText" Text="0" FontSize="22" FontWeight="600" Foreground="{StaticResource TextPrimary}"/>
                                        <TextBlock Text="OCR Ready" Style="{StaticResource TypographyBodySmall}" Margin="0,2,0,0"/>
                                    </StackPanel>
                                </StackPanel>

                                <Border Grid.Column="3" Background="{StaticResource BorderSubtle}"/>

                                <!-- AI Tagged -->
                                <StackPanel Grid.Column="4" Margin="20,16" Orientation="Horizontal">
                                    <Border Width="4" Height="40" CornerRadius="2" 
                                            Background="{StaticResource StatusSuccess}"
                                            Margin="0,0,16,0">
                                        <Border.Effect>
                                            <DropShadowEffect Color="#10B981" BlurRadius="8" ShadowDepth="0" Opacity="0.5"/>
                                        </Border.Effect>
                                    </Border>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock x:Name="AiTaggedCountText" Text="0" FontSize="22" FontWeight="600" Foreground="{StaticResource TextPrimary}"/>
                                        <TextBlock Text="AI Tagged" Style="{StaticResource TypographyBodySmall}" Margin="0,2,0,0"/>
                                    </StackPanel>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- Recent Screenshots Section -->
                        <Grid Margin="0,0,0,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Orientation="Horizontal">
                                <Border Width="8" Height="8" CornerRadius="4" 
                                        Background="{StaticResource AccentPrimary}"
                                        Margin="0,0,10,0" VerticalAlignment="Center">
                                    <Border.Effect>
                                        <DropShadowEffect Color="#8B5CF6" BlurRadius="6" ShadowDepth="0" Opacity="0.6"/>
                                    </Border.Effect>
                                </Border>
                                <TextBlock Text="Recent Screenshots"
                                           Style="{StaticResource TypographyTitleSmall}"
                                           Foreground="{StaticResource TextSecondary}"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                            <Button Grid.Column="1"
                                    Content="View all"
                                    Style="{StaticResource ButtonNav}"
                                    Foreground="{StaticResource AccentGlow}"
                                    FontSize="11"
                                    Click="Recent_Click"/>
                        </Grid>

                        <!-- Recent Lists -->
                        <StackPanel x:Name="RecentTodaySection" Margin="0,0,0,16">
                            <TextBlock Text="Today" Style="{StaticResource TypographyLabel}" Margin="0,0,0,10"/>
                            <ItemsControl x:Name="RecentTodayList" ItemTemplate="{StaticResource ScreenshotCardTemplate}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                            </ItemsControl>
                        </StackPanel>

                        <StackPanel x:Name="RecentYesterdaySection" Margin="0,0,0,16">
                            <TextBlock Text="Yesterday" Style="{StaticResource TypographyLabel}" Margin="0,0,0,10"/>
                            <ItemsControl x:Name="RecentYesterdayList" ItemTemplate="{StaticResource ScreenshotCardTemplate}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                            </ItemsControl>
                        </StackPanel>

                        <StackPanel x:Name="RecentWeekSection" Margin="0,0,0,16">
                            <TextBlock Text="This Week" Style="{StaticResource TypographyLabel}" Margin="0,0,0,10"/>
                            <ItemsControl x:Name="RecentWeekList" ItemTemplate="{StaticResource ScreenshotCardTemplate}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                            </ItemsControl>
                        </StackPanel>

                        <StackPanel x:Name="RecentOlderSection">
                            <TextBlock Text="Older" Style="{StaticResource TypographyLabel}" Margin="0,0,0,10"/>
                            <ItemsControl x:Name="RecentOlderList" ItemTemplate="{StaticResource ScreenshotCardTemplate}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                            </ItemsControl>
                        </StackPanel>

                    </StackPanel>

                    <!-- ══════════════════════════════════════════════
                         RESULTS PANEL
                    ══════════════════════════════════════════════ -->
                    <StackPanel x:Name="ResultsPanel" Visibility="Collapsed">

                        <Grid Margin="0,0,28,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock x:Name="ResultsTitleText" Text="Results" Style="{StaticResource TypographyTitleLarge}"/>
                                <TextBlock x:Name="ResultsMetaText" Text="0 result(s)" Style="{StaticResource TypographyBodyDefault}" Margin="0,4,0,0"/>
                            </StackPanel>
                            <Button Grid.Column="1"
                                    Style="{StaticResource ButtonSecondary}"
                                    Width="74"
                                    Height="34"
                                    Padding="0"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Top"
                                    Content="Back"
                                    Click="Home_Click"/>
                        </Grid>

                        <Border Height="3" Width="40" HorizontalAlignment="Left"
                                Background="{StaticResource AccentPrimary}" CornerRadius="1.5"
                                Margin="0,0,0,20">
                            <Border.Effect>
                                <DropShadowEffect Color="#8B5CF6" BlurRadius="8" ShadowDepth="0" Opacity="0.5"/>
                            </Border.Effect>
                        </Border>

                        <ItemsControl x:Name="ResultsList" ItemTemplate="{StaticResource ScreenshotCardTemplate}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                        </ItemsControl>

                    </StackPanel>

                    <!-- ══════════════════════════════════════════════
                         SETTINGS PANEL
                    ══════════════════════════════════════════════ -->
                    <Grid x:Name="SettingsPanel"
                          Visibility="Collapsed"
                          Width="{Binding ViewportWidth, ElementName=MainContentScrollViewer}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" Margin="0,0,28,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Settings" Style="{StaticResource TypographyTitleLarge}"/>
                                <TextBlock Text="Manage screenshot folders, OCR, and local AI processing."
                                           Style="{StaticResource TypographyBodyDefault}"
                                           Margin="0,4,0,0"/>
                            </StackPanel>
                            <Button Grid.Column="1"
                                    Style="{StaticResource ButtonSecondary}"
                                    Width="74"
                                    Height="34"
                                    Padding="0"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Top"
                                    Content="Back"
                                    Click="Home_Click"/>
                        </Grid>

                        <Border Grid.Row="1"
                                Height="3"
                                Width="40"
                                HorizontalAlignment="Left"
                                Background="{StaticResource AccentPrimary}"
                                CornerRadius="1.5"
                                Margin="0,0,0,20">
                            <Border.Effect>
                                <DropShadowEffect Color="#8B5CF6" BlurRadius="8" ShadowDepth="0" Opacity="0.5"/>
                            </Border.Effect>
                        </Border>

                        <Grid Grid.Row="2" Margin="0,0,28,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1*"/>
                                <ColumnDefinition Width="24"/>
                                <ColumnDefinition Width="1*"/>
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0"
                                    Background="{StaticResource SurfaceGlass}"
                                    BorderBrush="{StaticResource BorderSubtle}"
                                    BorderThickness="1"
                                    CornerRadius="16"
                                    Padding="18"
                                    VerticalAlignment="Top"
                                    Effect="{StaticResource SubtleShadow}">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <StackPanel Grid.Row="0">
                                        <TextBlock Text="Watched Folders" Style="{StaticResource TypographyTitleSmall}" FontSize="16"/>
                                        <TextBlock Text="Manage local directories for screenshot indexing."
                                                   Style="{StaticResource TypographyBodyDefault}"
                                                   Margin="0,4,0,12"/>
                                    </StackPanel>

                                    <Button Background="Transparent"
                                            Grid.Row="1"
                                            BorderThickness="0"
                                            Padding="0"
                                            Cursor="Hand"
                                            Click="AddSettingsFolder_Click">
                                        <Grid Height="104" Margin="0,0,0,12">
                                            <Rectangle RadiusX="14"
                                                       RadiusY="14"
                                                       Fill="#4D1A1B1F"
                                                       Stroke="{StaticResource AccentPrimary}"
                                                       StrokeThickness="1.4"
                                                       StrokeDashArray="4 4">
                                                <Rectangle.Effect>
                                                    <DropShadowEffect Color="#8B5CF6" BlurRadius="20" ShadowDepth="0" Opacity="0.35"/>
                                                </Rectangle.Effect>
                                            </Rectangle>
                                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                                <Viewbox Width="34" Height="34" HorizontalAlignment="Center">
                                                    <Path Data="M20 6h-8l-2-2H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V8c0-1.1-.9-2-2-2zm0 12H4V6h5.17l2 2H20v10z"
                                                          Fill="{StaticResource AccentGlow}"
                                                          Stretch="Uniform"/>
                                                </Viewbox>
                                                <TextBlock Text="Drag and drop folders here"
                                                           Foreground="{StaticResource TextPrimary}"
                                                           FontSize="13"
                                                           FontWeight="700"
                                                           HorizontalAlignment="Center"
                                                           Margin="0,8,0,0"/>
                                                <TextBlock Text="or click to browse"
                                                           Style="{StaticResource TypographyBodySmall}"
                                                           HorizontalAlignment="Center"
                                                           Margin="0,4,0,0"/>
                                            </StackPanel>
                                        </Grid>
                                    </Button>

                                    <Border x:Name="SettingsEmptyState"
                                            Grid.Row="2"
                                            Background="#661A1B1F"
                                            BorderBrush="{StaticResource BorderSubtle}"
                                            BorderThickness="1"
                                            CornerRadius="12"
                                            Padding="14,12"
                                            Margin="0,0,0,14"
                                            VerticalAlignment="Top">
                                        <StackPanel HorizontalAlignment="Center">
                                            <TextBlock Text="No folders added yet"
                                                       FontSize="13"
                                                       FontWeight="600"
                                                       Foreground="{StaticResource TextSecondary}"
                                                       HorizontalAlignment="Center"/>
                                            <TextBlock Text="Add a screenshot folder to begin indexing."
                                                       Style="{StaticResource TypographyBodySmall}"
                                                       HorizontalAlignment="Center"
                                                       Margin="0,4,0,0"/>
                                        </StackPanel>
                                    </Border>

                                    <ListBox x:Name="SettingsFoldersList"
                                             Grid.Row="2"
                                             Background="Transparent"
                                             BorderThickness="0"
                                             ItemContainerStyle="{StaticResource FolderListItem}"
                                             MinHeight="70"
                                             MaxHeight="170"
                                             Visibility="Collapsed"
                                             Margin="0,0,0,10"/>

                                    <Button Style="{StaticResource ButtonSecondary}"
                                            Grid.Row="3"
                                            Height="34"
                                            Click="AddSettingsFolder_Click">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="+" FontSize="16" FontWeight="600" Margin="0,-2,8,0"/>
                                            <TextBlock Text="Add Folder" FontWeight="600"/>
                                        </StackPanel>
                                    </Button>
                                </Grid>
                            </Border>

                            <StackPanel Grid.Column="2" VerticalAlignment="Top">
                                <Border Background="{StaticResource SurfaceGlass}"
                                        BorderBrush="{StaticResource BorderSubtle}"
                                        BorderThickness="1"
                                        CornerRadius="16"
                                        Padding="18"
                                        Margin="0,0,0,12"
                                        Effect="{StaticResource SubtleShadow}">
                                    <StackPanel>
                                        <Grid Margin="0,0,0,12">
                                            <StackPanel>
                                                <TextBlock Text="Processing" Style="{StaticResource TypographyTitleSmall}" FontSize="16"/>
                                                <TextBlock Text="Local OCR and AI status"
                                                           Style="{StaticResource TypographyBodySmall}"
                                                           Margin="0,4,0,0"/>
                                                <TextBlock Text="Active"
                                                           Foreground="{StaticResource StatusSuccessGlow}"
                                                           FontSize="12"
                                                           FontWeight="700"
                                                           Margin="0,2,0,0"/>
                                            </StackPanel>
                                            <CheckBox HorizontalAlignment="Right"
                                                      VerticalAlignment="Top"
                                                      Style="{StaticResource ToggleSwitchStyle}"
                                                      IsChecked="True"/>
                                        </Grid>

                                        <Grid Margin="0,0,0,8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="OCR Ready" Style="{StaticResource TypographyBodyDefault}"/>
                                            <TextBlock Grid.Column="1" x:Name="SettingsOcrReadyText" Text="0" Foreground="{StaticResource TextPrimary}" FontSize="13" FontWeight="700"/>
                                        </Grid>
                                        <Grid Margin="0,0,0,8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="AI Tagged" Style="{StaticResource TypographyBodyDefault}"/>
                                            <TextBlock Grid.Column="1" x:Name="SettingsAiTaggedText" Text="0" Foreground="{StaticResource TextPrimary}" FontSize="13" FontWeight="700"/>
                                        </Grid>
                                        <Grid Margin="0,0,0,8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="Tasks in Queue" Style="{StaticResource TypographyBodyDefault}"/>
                                            <TextBlock Grid.Column="1" x:Name="SettingsAiPendingText" Text="0" Foreground="{StaticResource TextPrimary}" FontSize="13" FontWeight="700"/>
                                        </Grid>
                                        <Grid Margin="0,0,0,12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="AI Model" Style="{StaticResource TypographyBodyDefault}"/>
                                            <TextBlock Grid.Column="1" x:Name="SettingsAiModeText" Text="Heuristic" Foreground="{StaticResource AccentGlow}" FontSize="13" FontWeight="700"/>
                                        </Grid>
                                        <Button Content="Run AI Backfill"
                                                Style="{StaticResource ButtonPrimary}"
                                                Height="36"
                                                Padding="14,0"
                                                Click="RunAiBackfill_Click"/>
                                    </StackPanel>
                                </Border>

                                <Border Background="{StaticResource SurfaceGlass}"
                                        BorderBrush="{StaticResource BorderSubtle}"
                                        BorderThickness="1"
                                        CornerRadius="16"
                                        Padding="18">
                                    <StackPanel>
                                        <Grid Margin="0,0,0,14">
                                            <TextBlock Text="Library Statistics" Style="{StaticResource TypographyTitleSmall}" FontSize="16"/>
                                            <CheckBox HorizontalAlignment="Right" Style="{StaticResource ToggleSwitchStyle}" IsChecked="True"/>
                                        </Grid>
                                        <Grid Margin="0,0,0,10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="Imported" Style="{StaticResource TypographyBodyDefault}"/>
                                            <TextBlock Grid.Column="1" x:Name="SettingsImportedText" Text="0" Foreground="{StaticResource TextPrimary}" FontSize="13" FontWeight="700"/>
                                        </Grid>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="Watched Folders" Style="{StaticResource TypographyBodyDefault}"/>
                                            <TextBlock Grid.Column="1" x:Name="SettingsFolderCountText" Text="0" Foreground="{StaticResource TextPrimary}" FontSize="13" FontWeight="700"/>
                                        </Grid>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Grid>
                    </Grid>

                    <!-- ══════════════════════════════════════════════
                         LICENSE PANEL
                    ══════════════════════════════════════════════ -->
                    <Grid x:Name="LicensePanel"
                          Visibility="Collapsed"
                          Width="{Binding ViewportWidth, ElementName=MainContentScrollViewer}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" Margin="0,0,28,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="License" Style="{StaticResource TypographyTitleLarge}"/>
                                <TextBlock Text="Manage ScreenMemory AI Pro and your local memory limit."
                                           Style="{StaticResource TypographyBodyDefault}"
                                           Margin="0,4,0,0"/>
                            </StackPanel>
                            <Button Grid.Column="1"
                                        Style="{StaticResource ButtonSecondary}"
                                        Width="74"
                                        Height="34"
                                        Padding="0"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Top"
                                        Content="Back"
                                        Click="Home_Click"/>
                            <Button Grid.Column="1"
                                    x:Name="LicensePageUpgradeButton"
                                    Style="{StaticResource ButtonPrimary}"
                                    Height="36"
                                    Padding="18,0"
                                    VerticalAlignment="Top"
                                    Visibility="Collapsed"
                                    Click="UpgradeLicense_Click"/>
                        </Grid>

                        <Border Grid.Row="1"
                                Height="3"
                                Width="40"
                                HorizontalAlignment="Left"
                                Background="{StaticResource AccentPrimary}"
                                CornerRadius="1.5"
                                Margin="0,0,0,20">
                            <Border.Effect>
                                <DropShadowEffect Color="#8B5CF6" BlurRadius="8" ShadowDepth="0" Opacity="0.5"/>
                            </Border.Effect>
                        </Border>

                        <Grid Grid.Row="2" Margin="0,0,28,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1*"/>
                                <ColumnDefinition Width="24"/>
                                <ColumnDefinition Width="1*"/>
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0"
                                    BorderBrush="{StaticResource BorderDefault}"
                                    BorderThickness="1"
                                    CornerRadius="14"
                                    Padding="20"
                                    VerticalAlignment="Top">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#18191F" Offset="0"/>
                                        <GradientStop Color="#12131A" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <StackPanel>
                                    <Grid Margin="0,0,0,14">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="Current Plan"
                                                       Style="{StaticResource TypographyTitleMedium}"/>
                                            <TextBlock x:Name="SettingsLicenseUsageText"
                                                       Text="0/200 free screenshots"
                                                       Style="{StaticResource TypographyBodyDefault}"
                                                       Margin="0,5,0,0"/>
                                        </StackPanel>
                                        <Border Grid.Column="1"
                                                Background="{StaticResource AccentSubtle}"
                                                BorderBrush="{StaticResource AccentPrimary}"
                                                BorderThickness="1"
                                                CornerRadius="8"
                                                Padding="12,6"
                                                VerticalAlignment="Top">
                                            <TextBlock x:Name="SettingsLicensePlanText"
                                                       Text="Free"
                                                       FontSize="12"
                                                       FontWeight="700"
                                                       Foreground="{StaticResource AccentGlow}"/>
                                        </Border>
                                    </Grid>

                                    <Border Height="10"
                                            CornerRadius="5"
                                            Background="{StaticResource BackgroundPrimary}"
                                            BorderBrush="{StaticResource BorderSubtle}"
                                            BorderThickness="1"
                                            Margin="0,0,0,10">
                                        <Grid ClipToBounds="True">
                                            <Border x:Name="LicenseUsageBar"
                                                    Width="0"
                                                    HorizontalAlignment="Left"
                                                    CornerRadius="5"
                                                    Background="{StaticResource AccentGlowGradient}"/>
                                        </Grid>
                                    </Border>

                                    <TextBlock x:Name="SettingsLicenseStatusText"
                                               Text="Free plan includes 200 fully searchable screenshots."
                                               Style="{StaticResource TypographyBodyDefault}"
                                               TextWrapping="Wrap"
                                               Margin="0,0,0,14"/>

                                    <TextBlock Text="License key"
                                               Style="{StaticResource TypographyLabel}"
                                               Margin="0,0,0,8"/>
                                    <TextBox x:Name="SettingsLicenseKeyBox"
                                             Height="40"
                                             Background="{StaticResource BackgroundPrimary}"
                                             Foreground="{StaticResource TextPrimary}"
                                             CaretBrush="{StaticResource AccentPrimary}"
                                             BorderBrush="{StaticResource BorderDefault}"
                                             BorderThickness="1"
                                             Padding="12,0"
                                             VerticalContentAlignment="Center"
                                             FontSize="12"
                                             Margin="0,0,0,12"
                                             ToolTip="Paste your Lemon Squeezy license key"/>

                                    <StackPanel Orientation="Horizontal">
                                        <Button Content="Activate License"
                                                Style="{StaticResource ButtonPrimary}"
                                                Height="36"
                                                Padding="18,0"
                                                Click="ActivateLicense_Click"/>
                                        <Button Content="Open Checkout"
                                                Style="{StaticResource ButtonSecondary}"
                                                Height="36"
                                                Padding="16,0"
                                                Margin="10,0,0,0"
                                                Click="UpgradeLicense_Click"/>
                                        <Button x:Name="DeactivateLicenseButton"
                                                Content="Deactivate Device"
                                                Style="{StaticResource ButtonSecondary}"
                                                Height="36"
                                                Padding="16,0"
                                                Margin="10,0,0,0"
                                                Click="DeactivateLicense_Click"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <StackPanel Grid.Column="2" VerticalAlignment="Top">
                                <Border Background="{StaticResource BackgroundTertiary}"
                                        BorderBrush="{StaticResource BorderSubtle}"
                                        BorderThickness="1"
                                        CornerRadius="12"
                                        Padding="16"
                                        Margin="0,0,0,12">
                                    <StackPanel>
                                        <TextBlock Text="Free" Style="{StaticResource TypographyTitleSmall}"/>
                                        <TextBlock Text="Try the full product with a local screenshot memory limit."
                                                   Style="{StaticResource TypographyBodySmall}"
                                                   TextWrapping="Wrap"
                                                   Margin="0,5,0,12"/>
                                        <TextBlock Text="200 screenshots" Style="{StaticResource TypographyBodyDefault}"/>
                                        <TextBlock Text="OCR + AI search included" Style="{StaticResource TypographyBodyDefault}" Margin="0,8,0,0"/>
                                        <TextBlock Text="Local-only processing" Style="{StaticResource TypographyBodyDefault}" Margin="0,8,0,0"/>
                                    </StackPanel>
                                </Border>

                                <Border BorderBrush="{StaticResource AccentPrimary}"
                                        BorderThickness="1"
                                        CornerRadius="12"
                                        Padding="16">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#1E1832" Offset="0"/>
                                            <GradientStop Color="#111217" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <StackPanel>
                                        <TextBlock Text="Pro"
                                                   Style="{StaticResource TypographyTitleSmall}"
                                                   Foreground="{StaticResource AccentGlow}"
                                                   Margin="0,0,0,8"/>
                                        <TextBlock Text="Unlimited local memory for screenshots and semantic search."
                                                   Style="{StaticResource TypographyBodySmall}"
                                                   TextWrapping="Wrap"
                                                   Margin="0,0,0,12"/>
                                        <TextBlock Text="Unlimited screenshots" Style="{StaticResource TypographyBodyDefault}"/>
                                        <TextBlock Text="Device activation via Lemon Squeezy" Style="{StaticResource TypographyBodyDefault}" Margin="0,8,0,0"/>
                                        <TextBlock Text="Works offline after activation" Style="{StaticResource TypographyBodyDefault}" Margin="0,8,0,0"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Grid>
                    </Grid>

                </Grid>
            </ScrollViewer>
        </DockPanel>

        <!-- ╔════════════════════════════════════════════════════╗
             ║              SIDE PREVIEW PANEL                   ║
             ╚════════════════════════════════════════════════════╝ -->
        <Border x:Name="PreviewPanel"
                Grid.Column="2"
                Background="{StaticResource BackgroundSecondary}"
                BorderBrush="{StaticResource BorderSubtle}"
                BorderThickness="1,0,0,0">
            <DockPanel>

                <Border DockPanel.Dock="Top"
                        Padding="18,14,14,14"
                        BorderBrush="{StaticResource BorderSubtle}"
                        BorderThickness="0,0,0,1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                            <Border Width="8" Height="8" CornerRadius="4" 
                                    Background="{StaticResource AccentPrimary}"
                                    Margin="0,0,10,0">
                                <Border.Effect>
                                    <DropShadowEffect Color="#8B5CF6" BlurRadius="6" ShadowDepth="0" Opacity="0.6"/>
                                </Border.Effect>
                            </Border>
                            <TextBlock Text="Preview" Style="{StaticResource TypographyTitleSmall}" VerticalAlignment="Center"/>
                        </StackPanel>
                        <Button Grid.Column="1" Content="&#xE8BB;" Style="{StaticResource ButtonWindowControlClose}" Width="30" Height="30" Click="PreviewClose_Click"/>
                    </Grid>
                </Border>

                <Border DockPanel.Dock="Bottom"
                        Padding="14,14"
                        BorderBrush="{StaticResource BorderSubtle}"
                        BorderThickness="0,1,0,0">
                    <StackPanel Orientation="Horizontal">
                        <Button x:Name="PreviewOpenImageButton" Content="Open" Style="{StaticResource ButtonPrimary}" Height="34" Padding="16,0" Click="PreviewOpenImage_Click"/>
                        <Button x:Name="PreviewRevealButton" Content="Reveal" Style="{StaticResource ButtonSecondary}" Height="34" Padding="14,0" Margin="8,0,0,0" Click="PreviewReveal_Click"/>
                        <Button Content="Copy" Style="{StaticResource ButtonSecondary}" Height="34" Padding="14,0" Margin="8,0,0,0" Click="PreviewCopyPath_Click"/>
                        <Button x:Name="PreviewFavoriteButton" Style="{StaticResource ButtonSecondary}" Height="34" Padding="12,0" Margin="8,0,0,0" Click="PreviewFavorite_Click" ToolTip="Add to favourites">
                            <TextBlock Text="&#xE734;" FontFamily="Segoe MDL2 Assets" FontSize="11"/>
                        </Button>
                    </StackPanel>
                </Border>

                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16,0">
                    <StackPanel Margin="0,16,0,0">

                        <Border Height="170"
                                Background="{StaticResource BackgroundPrimary}"
                                CornerRadius="12"
                                Margin="0,0,0,18"
                                ClipToBounds="True"
                                Effect="{StaticResource SubtleShadow}">
                            <Grid>
                                <Image x:Name="PreviewImage" Stretch="Uniform" VerticalAlignment="Center"/>
                                <TextBlock x:Name="PreviewPlaceholderText" Text="Loading" Style="{StaticResource TypographyBodyDefault}" Foreground="{StaticResource TextMuted}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>

                        <TextBlock Text="FILE NAME" Style="{StaticResource TypographyLabel}" Margin="0,0,0,6"/>
                        <TextBlock x:Name="PreviewFileNameText" Style="{StaticResource TypographyBodyDefault}" Foreground="{StaticResource TextPrimary}" TextWrapping="Wrap" Margin="0,0,0,16"/>

                        <TextBlock Text="CREATED" Style="{StaticResource TypographyLabel}" Margin="0,0,0,6"/>
                        <TextBlock x:Name="PreviewCreatedAtText" Style="{StaticResource TypographyBodyDefault}" Margin="0,0,0,16"/>

                        <TextBlock Text="SIZE" Style="{StaticResource TypographyLabel}" Margin="0,0,0,6"/>
                        <TextBlock x:Name="PreviewFileSizeText" Style="{StaticResource TypographyBodyDefault}" Margin="0,0,0,16"/>

                        <!-- OCR Status with Badge -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                            <Border Background="{StaticResource StatusInfoSubtle}"
                                    BorderBrush="{StaticResource StatusInfo}"
                                    BorderThickness="1"
                                    CornerRadius="6"
                                    Padding="8,4">
                                <StackPanel Orientation="Horizontal">
                                    <Border Width="6" Height="6" CornerRadius="3" Background="{StaticResource StatusInfo}" Margin="0,0,6,0">
                                        <Border.Effect>
                                            <DropShadowEffect Color="#3B82F6" BlurRadius="4" ShadowDepth="0" Opacity="0.6"/>
                                        </Border.Effect>
                                    </Border>
                                    <TextBlock Text="OCR" FontSize="10" FontWeight="600" Foreground="{StaticResource StatusInfo}"/>
                                </StackPanel>
                            </Border>
                            <TextBlock x:Name="PreviewOcrStatusText"
                                       Style="{StaticResource TypographyBodyDefault}"
                                       Foreground="{StaticResource TextSecondary}"
                                       VerticalAlignment="Center"
                                       Margin="10,0,0,0"/>
                        </StackPanel>

                        <TextBlock Text="AI CATEGORY" Style="{StaticResource TypographyLabel}" Margin="0,0,0,6"/>
                        <TextBlock x:Name="PreviewAiCategoryText"
                                   Style="{StaticResource TypographyBodyDefault}"
                                   Foreground="{StaticResource AccentGlow}"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,12"/>

                        <TextBlock Text="AI TAGS" Style="{StaticResource TypographyLabel}" Margin="0,0,0,6"/>
                        <TextBlock x:Name="PreviewAiTagsText"
                                   Style="{StaticResource TypographyBodySmall}"
                                   Foreground="{StaticResource TextSecondary}"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,16"/>

                        <TextBlock Text="APPLICATION" Style="{StaticResource TypographyLabel}" Margin="0,0,0,6"/>
                        <TextBlock x:Name="PreviewApplicationText"
                                   Style="{StaticResource TypographyBodyDefault}"
                                   Foreground="{StaticResource TextPrimary}"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,12"/>

                        <TextBlock Text="WINDOW" Style="{StaticResource TypographyLabel}" Margin="0,0,0,6"/>
                        <TextBlock x:Name="PreviewWindowText"
                                   Style="{StaticResource TypographyBodySmall}"
                                   Foreground="{StaticResource TextMuted}"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,16"/>

                        <TextBlock Text="AI SUMMARY" Style="{StaticResource TypographyLabel}" Margin="0,0,0,6"/>
                        <TextBlock x:Name="PreviewAiSummaryText"
                                   Style="{StaticResource TypographyBodySmall}"
                                   Foreground="{StaticResource TextSecondary}"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,16"/>

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                            <Border Background="{StaticResource AccentSubtle}"
                                    BorderBrush="{StaticResource AccentPrimary}"
                                    BorderThickness="1"
                                    CornerRadius="6"
                                    Padding="8,4">
                                <TextBlock Text="AI" FontSize="10" FontWeight="600" Foreground="{StaticResource AccentGlow}"/>
                            </Border>
                            <TextBlock x:Name="PreviewAiStatusText"
                                       Style="{StaticResource TypographyBodyDefault}"
                                       Foreground="{StaticResource TextSecondary}"
                                       VerticalAlignment="Center"
                                       Margin="10,0,0,0"/>
                        </StackPanel>

                        <TextBlock Text="PATH" Style="{StaticResource TypographyLabel}" Margin="0,0,0,6"/>
                        <TextBlock x:Name="PreviewFilePathText" Style="{StaticResource TypographyBodySmall}" Foreground="{StaticResource TextMuted}" TextWrapping="Wrap"/>

                    </StackPanel>
                </ScrollViewer>

            </DockPanel>
        </Border>

    </Grid>
</Window>
