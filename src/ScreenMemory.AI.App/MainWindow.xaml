<Window x:Class="ScreenMemory.AI.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ScreenMemory AI"
        Height="720"
        Width="1140"
        MinHeight="600"
        MinWidth="920"
        WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI Variable Display, Segoe UI, sans-serif"
        Background="#ECEEF2">

    <Window.Resources>

        <!-- COLOR PALETTE -->
        <SolidColorBrush x:Key="AccentBrush"        Color="#4F46E5"/>
        <SolidColorBrush x:Key="AccentLightBrush"   Color="#EEF2FF"/>
        <SolidColorBrush x:Key="SurfaceBrush"       Color="#FFFFFF"/>
        <SolidColorBrush x:Key="BorderBrush"        Color="#E2E8F0"/>
        <SolidColorBrush x:Key="TextPrimaryBrush"   Color="#0F172A"/>
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="#64748B"/>
        <SolidColorBrush x:Key="TextTertiaryBrush"  Color="#94A3B8"/>
        <SolidColorBrush x:Key="GreenBrush"         Color="#22C55E"/>

        <!-- Primary Button -->
        <Style x:Key="PrimaryBtn" TargetType="Button">
            <Setter Property="Background"      Value="#4F46E5"/>
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="FontFamily"      Value="Segoe UI Variable Display, Segoe UI"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"         Value="18,0"/>
            <Setter Property="Height"          Value="38"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="9"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#4338CA"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#3730A3"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Ghost Button -->
        <Style x:Key="GhostBtn" TargetType="Button">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="Foreground"      Value="#64748B"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="FontFamily"      Value="Segoe UI Variable Display, Segoe UI"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="BorderBrush"     Value="#CBD5E1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"         Value="16,0"/>
            <Setter Property="Height"          Value="38"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="9"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#F8FAFC"/>
                                <Setter TargetName="bd" Property="BorderBrush" Value="#94A3B8"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#F1F5F9"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Large CTA Buttons -->
        <Style x:Key="PrimaryBtnLg" TargetType="Button" BasedOn="{StaticResource PrimaryBtn}">
            <Setter Property="Height"   Value="44"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding"  Value="26,0"/>
        </Style>

        <Style x:Key="GhostBtnLg" TargetType="Button" BasedOn="{StaticResource GhostBtn}">
            <Setter Property="Height"   Value="44"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding"  Value="22,0"/>
        </Style>

        <!-- Nav Button -->
        <Style x:Key="NavBtn" TargetType="Button">
            <Setter Property="Background"                 Value="Transparent"/>
            <Setter Property="Foreground"                 Value="#64748B"/>
            <Setter Property="FontSize"                   Value="13"/>
            <Setter Property="FontFamily"                 Value="Segoe UI Variable Display, Segoe UI"/>
            <Setter Property="Cursor"                     Value="Hand"/>
            <Setter Property="BorderThickness"            Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding"                    Value="10,9"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#F8FAFC"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#EEF2FF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Active Nav Button -->
        <Style x:Key="NavBtnActive" TargetType="Button" BasedOn="{StaticResource NavBtn}">
            <Setter Property="Background" Value="#EEF2FF"/>
            <Setter Property="Foreground" Value="#4F46E5"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <!-- Chip Button -->
        <Style x:Key="ChipBtn" TargetType="Button">
            <Setter Property="Background"      Value="#F8FAFC"/>
            <Setter Property="Foreground"      Value="#64748B"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="FontFamily"      Value="Segoe UI Variable Display, Segoe UI"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="BorderBrush"     Value="#E2E8F0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"         Value="12,5"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="20"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background"  Value="#EEF2FF"/>
                                <Setter TargetName="bd" Property="BorderBrush" Value="#4F46E5"/>
                                <Setter Property="Foreground" Value="#4F46E5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Search TextBox -->
        <Style x:Key="SearchBoxStyle" TargetType="TextBox">
            <Setter Property="FontSize"                 Value="15"/>
            <Setter Property="FontFamily"               Value="Segoe UI Variable Display, Segoe UI"/>
            <Setter Property="Foreground"               Value="#0F172A"/>
            <Setter Property="Background"               Value="Transparent"/>
            <Setter Property="BorderThickness"          Value="0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding"                  Value="0,6"/>
            <Setter Property="CaretBrush"               Value="#4F46E5"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <ScrollViewer x:Name="PART_ContentHost" VerticalAlignment="Center"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Sidebar Separator -->
        <Style x:Key="SidebarSep" TargetType="Separator">
            <Setter Property="Background" Value="#E2E8F0"/>
            <Setter Property="Height"     Value="1"/>
            <Setter Property="Margin"     Value="0,14,0,14"/>
        </Style>

    </Window.Resources>

    <!-- ROOT -->
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="230"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ===== SIDEBAR ===== -->
        <Border Grid.Column="0"
                Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,1,0">
            <DockPanel>

                <!-- Brand header -->
                <Border DockPanel.Dock="Top"
                        Padding="20,20,20,16"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="0,0,0,1">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Width="34" Height="34"
                                Background="{StaticResource AccentLightBrush}"
                                CornerRadius="10"
                                Margin="0,0,10,0">
                            <TextBlock Text="&#x1F4F8;"
                                       FontSize="17"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="ScreenMemory"
                                       FontSize="15"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                            <TextBlock Text="AI"
                                       FontSize="11"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource AccentBrush}"
                                       Margin="0,-1,0,0"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Status footer -->
                <Border DockPanel.Dock="Bottom"
                        Padding="16,14"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="0,1,0,0">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                            <Ellipse Width="7" Height="7"
                                     Fill="{StaticResource GreenBrush}"
                                     VerticalAlignment="Center"
                                     Margin="0,0,7,0"/>
                            <TextBlock Text="Ready"
                                       FontSize="12"
                                       Foreground="{StaticResource TextSecondaryBrush}"/>
                        </StackPanel>
                        <TextBlock Text="Imported: 0  &#xB7;  OCR: 0  &#xB7;  Tagged: 0"
                                   FontSize="11"
                                   Foreground="{StaticResource TextTertiaryBrush}"/>
                    </StackPanel>
                </Border>

                <!-- Nav items -->
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="12,16,12,0">

                        <TextBlock Text="BROWSE"
                                   FontSize="10"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextTertiaryBrush}"
                                   Margin="10,0,0,8"/>

                        <Button Style="{StaticResource NavBtnActive}" Margin="0,0,0,2">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#x229E;" FontSize="14" Margin="0,0,9,0" VerticalAlignment="Center"/>
                                <TextBlock Text="All Screenshots" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button Style="{StaticResource NavBtn}" Margin="0,0,0,2">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#x25F7;" FontSize="14" Margin="0,0,9,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Today" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button Style="{StaticResource NavBtn}" Margin="0,0,0,2">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#x1F4C5;" FontSize="13" Margin="0,0,9,0" VerticalAlignment="Center"/>
                                <TextBlock Text="This Week" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button Style="{StaticResource NavBtn}" Margin="0,0,0,2">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#x2605;" FontSize="14" Margin="0,0,9,0"
                                           VerticalAlignment="Center" Foreground="#F59E0B"/>
                                <TextBlock Text="Favorites" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Separator Style="{StaticResource SidebarSep}"/>

                        <TextBlock Text="SMART FILTERS"
                                   FontSize="10"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextTertiaryBrush}"
                                   Margin="10,0,0,8"/>

                        <Button Style="{StaticResource NavBtn}" Margin="0,0,0,2">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#x1F9FE;" FontSize="13" Margin="0,0,9,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Invoices" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button Style="{StaticResource NavBtn}" Margin="0,0,0,2">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#x26A0;" FontSize="13" Margin="0,0,9,0"
                                           VerticalAlignment="Center" Foreground="#EF4444"/>
                                <TextBlock Text="Errors" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button Style="{StaticResource NavBtn}" Margin="0,0,0,2">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&lt;/&gt;" FontSize="12" Margin="0,0,9,0"
                                           VerticalAlignment="Center"
                                           Foreground="{StaticResource AccentBrush}"
                                           FontFamily="Cascadia Code, Consolas"/>
                                <TextBlock Text="Code Snippets" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button Style="{StaticResource NavBtn}" Margin="0,0,0,2">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#x1F4AC;" FontSize="13" Margin="0,0,9,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Conversations" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                    </StackPanel>
                </ScrollViewer>
            </DockPanel>
        </Border>

        <!-- ===== CONTENT AREA ===== -->
        <DockPanel Grid.Column="1">

            <!-- Top bar -->
            <Border DockPanel.Dock="Top"
                    Background="{StaticResource SurfaceBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="0,0,0,1"
                    Padding="20,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Search bar -->
                    <Border Grid.Column="0"
                            Background="#F8FAFC"
                            BorderBrush="#E2E8F0"
                            BorderThickness="1"
                            CornerRadius="10"
                            Padding="14,0"
                            Height="40"
                            Margin="0,0,12,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0"
                                       Text="&#x1F50D;"
                                       FontSize="15"
                                       VerticalAlignment="Center"
                                       Margin="0,0,10,0"/>

                            <TextBox Grid.Column="1"
                                     x:Name="SearchBox"
                                     Style="{StaticResource SearchBoxStyle}"/>

                            <!-- Placeholder overlay -->
                            <TextBlock Grid.Column="1"
                                       Text="Try &quot;Stripe receipt&quot; or &quot;terminal error last week&quot;..."
                                       FontSize="14"
                                       Foreground="{StaticResource TextTertiaryBrush}"
                                       VerticalAlignment="Center"
                                       IsHitTestVisible="False">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Text, ElementName=SearchBox}" Value="">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>

                            <Border Grid.Column="2"
                                    Background="White"
                                    BorderBrush="#E2E8F0"
                                    BorderThickness="1"
                                    CornerRadius="5"
                                    Padding="6,2"
                                    VerticalAlignment="Center">
                                <TextBlock Text="Ctrl+K"
                                           FontSize="11"
                                           Foreground="{StaticResource TextTertiaryBrush}"
                                           FontFamily="Cascadia Code, Consolas"/>
                            </Border>
                        </Grid>
                    </Border>

                    <!-- Action buttons -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <Button Content="Settings"
                            Style="{StaticResource GhostBtn}"
                            Margin="0,0,8,0"
                            Click="Settings_Click"/>
                        <Button Content="Index Now"
                                Style="{StaticResource PrimaryBtn}"
                                Padding="18,0"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Status bar -->
            <Border DockPanel.Dock="Bottom"
                    Background="{StaticResource SurfaceBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="0,1,0,0"
                    Padding="20,8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Ellipse Width="7" Height="7"
                                 Fill="{StaticResource GreenBrush}"
                                 VerticalAlignment="Center"
                                 Margin="0,0,7,0"/>
                        <TextBlock Text="Ready"
                                   FontSize="12"
                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                    </StackPanel>
                    <TextBlock Grid.Column="1"
                               Text="0 screenshots indexed"
                               FontSize="12"
                               Foreground="{StaticResource TextTertiaryBrush}"
                               VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <!-- Scrollable body -->
            <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="24">
                <StackPanel>

                    <!-- STAT CARDS -->
                    <Grid Margin="0,0,0,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Indexed -->
                        <Border Grid.Column="0"
                                Background="{StaticResource SurfaceBrush}"
                                BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="14"
                                Padding="20,18">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                    <Border Width="32" Height="32"
                                            Background="#EEF2FF"
                                            CornerRadius="8"
                                            Margin="0,0,10,0">
                                        <TextBlock Text="&#x1F5BC;"
                                                   FontSize="15"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Border>
                                    <TextBlock Text="Indexed"
                                               FontSize="12"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource TextTertiaryBrush}"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                                <TextBlock Text="0"
                                           FontSize="30"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           Margin="0,0,0,4"/>
                                <TextBlock Text="screenshots total"
                                           FontSize="12"
                                           Foreground="{StaticResource TextTertiaryBrush}"/>
                            </StackPanel>
                        </Border>

                        <!-- OCR Ready -->
                        <Border Grid.Column="2"
                                Background="{StaticResource SurfaceBrush}"
                                BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="14"
                                Padding="20,18">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                    <Border Width="32" Height="32"
                                            Background="#F0FDF4"
                                            CornerRadius="8"
                                            Margin="0,0,10,0">
                                        <TextBlock Text="&#x1F4C4;"
                                                   FontSize="15"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Border>
                                    <TextBlock Text="OCR Ready"
                                               FontSize="12"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource TextTertiaryBrush}"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                                <TextBlock Text="0"
                                           FontSize="30"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           Margin="0,0,0,4"/>
                                <TextBlock Text="text extracted"
                                           FontSize="12"
                                           Foreground="{StaticResource TextTertiaryBrush}"/>
                            </StackPanel>
                        </Border>

                        <!-- AI Tagged -->
                        <Border Grid.Column="4"
                                Background="{StaticResource SurfaceBrush}"
                                BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="14"
                                Padding="20,18">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                    <Border Width="32" Height="32"
                                            Background="#FFF7ED"
                                            CornerRadius="8"
                                            Margin="0,0,10,0">
                                        <TextBlock Text="&#x1F9E0;"
                                                   FontSize="15"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Border>
                                    <TextBlock Text="AI Tagged"
                                               FontSize="12"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource TextTertiaryBrush}"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                                <TextBlock Text="0"
                                           FontSize="30"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           Margin="0,0,0,4"/>
                                <TextBlock Text="auto-categorised"
                                           FontSize="12"
                                           Foreground="{StaticResource TextTertiaryBrush}"/>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <!-- EMPTY STATE CARD -->
                    <Border Background="{StaticResource SurfaceBrush}"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="18"
                            Padding="60,56">
                        <StackPanel HorizontalAlignment="Center" MaxWidth="460">

                            <Border Width="88" Height="88"
                                    Background="{StaticResource AccentLightBrush}"
                                    CornerRadius="24"
                                    HorizontalAlignment="Center"
                                    Margin="0,0,0,24">
                                <TextBlock Text="&#x1F4F8;"
                                           FontSize="40"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Border>

                            <TextBlock Text="No screenshots indexed yet"
                                       FontSize="24"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       HorizontalAlignment="Center"
                                       Margin="0,0,0,12"/>

                            <TextBlock Text="Choose your screenshot folders and ScreenMemory AI will build a private, searchable memory of every screenshot on your PC - powered by OCR and AI tagging."
                                       FontSize="14"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       TextWrapping="Wrap"
                                       TextAlignment="Center"
                                       LineHeight="22"
                                       Margin="0,0,0,30"/>

                            <StackPanel Orientation="Horizontal"
                                        HorizontalAlignment="Center"
                                        Margin="0,0,0,30">
                                <Button Content="Choose Folders"
                                    Style="{StaticResource PrimaryBtnLg}"
                                    Margin="0,0,10,0"
                                    Click="Settings_Click"/>
                                <Button Content="Learn More"
                                        Style="{StaticResource GhostBtnLg}"/>
                            </StackPanel>

                            <!-- Divider -->
                            <StackPanel Orientation="Horizontal"
                                        HorizontalAlignment="Center"
                                        Margin="0,0,0,18">
                                <Rectangle Width="60" Height="1" Fill="#E2E8F0" VerticalAlignment="Center"/>
                                <TextBlock Text="  example searches  "
                                           FontSize="11"
                                           Foreground="{StaticResource TextTertiaryBrush}"
                                           VerticalAlignment="Center"/>
                                <Rectangle Width="60" Height="1" Fill="#E2E8F0" VerticalAlignment="Center"/>
                            </StackPanel>

                            <!-- Hint chips -->
                            <WrapPanel HorizontalAlignment="Center">
                                <Button Content="Stripe receipt"    Style="{StaticResource ChipBtn}" Margin="4"/>
                                <Button Content="terminal error"    Style="{StaticResource ChipBtn}" Margin="4"/>
                                <Button Content="invoice last week" Style="{StaticResource ChipBtn}" Margin="4"/>
                                <Button Content="Python snippet"    Style="{StaticResource ChipBtn}" Margin="4"/>
                                <Button Content="Figma mockup"      Style="{StaticResource ChipBtn}" Margin="4"/>
                            </WrapPanel>

                        </StackPanel>
                    </Border>

                </StackPanel>
            </ScrollViewer>

        </DockPanel>
    </Grid>
</Window>
