<Window x:Class="ScreenMemory.AI.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ScreenMemory AI"
        Height="760"
        Width="1200"
        MinHeight="640"
        MinWidth="960"
        WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI Variable Display, Segoe UI, sans-serif"
        Background="#0D0F14">

    <Window.Resources>

        <!-- ═══════════════════════════════════════
             COLOR PALETTE
        ═══════════════════════════════════════ -->
        <SolidColorBrush x:Key="BgBase"            Color="#0D0F14"/>
        <SolidColorBrush x:Key="BgSurface"         Color="#13161D"/>
        <SolidColorBrush x:Key="BgCard"            Color="#181C25"/>
        <SolidColorBrush x:Key="BgCardHover"       Color="#1E2330"/>
        <SolidColorBrush x:Key="BorderSubtle"      Color="#1F2533"/>
        <SolidColorBrush x:Key="BorderMed"         Color="#293044"/>
        <SolidColorBrush x:Key="AccentPrimary"     Color="#6366F1"/>
        <SolidColorBrush x:Key="AccentGlow"        Color="#818CF8"/>
        <SolidColorBrush x:Key="AccentMuted"       Color="#1E2040"/>
        <SolidColorBrush x:Key="TextPrimary"       Color="#F0F2F8"/>
        <SolidColorBrush x:Key="TextSecondary"     Color="#8892A4"/>
        <SolidColorBrush x:Key="TextMuted"         Color="#4A5568"/>
        <SolidColorBrush x:Key="StatusGreen"       Color="#10B981"/>
        <SolidColorBrush x:Key="TagBg"             Color="#1A2035"/>

        <!-- ═══════════════════════════════════════
             NAV BUTTON STYLE
        ═══════════════════════════════════════ -->
        <Style x:Key="NavButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="12,9"/>
            <Setter Property="Margin" Value="0,1,0,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Foreground" Value="#8892A4"/>
            <Setter Property="FontSize" Value="13.5"/>
            <Setter Property="FontFamily" Value="Segoe UI Variable Display, Segoe UI, sans-serif"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="7"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1A1F2E"/>
                                <Setter Property="Foreground" Value="#C8CFDD"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1E2340"/>
                                <Setter Property="Foreground" Value="#6366F1"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══════════════════════════════════════
             ACTIVE NAV BUTTON (accent highlight)
        ═══════════════════════════════════════ -->
        <Style x:Key="NavButtonActive" TargetType="Button" BasedOn="{StaticResource NavButton}">
            <Setter Property="Background" Value="#1C203A"/>
            <Setter Property="Foreground" Value="#818CF8"/>
        </Style>

        <!-- ═══════════════════════════════════════
             PRIMARY ACTION BUTTON
        ═══════════════════════════════════════ -->
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#6366F1"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontFamily" Value="Segoe UI Variable Display, Segoe UI, sans-serif"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#7577F3"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#4F51C8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══════════════════════════════════════
             GHOST / SECONDARY BUTTON
        ═══════════════════════════════════════ -->
        <Style x:Key="GhostButton" TargetType="Button">
            <Setter Property="Background" Value="#1A1F2E"/>
            <Setter Property="Foreground" Value="#8892A4"/>
            <Setter Property="BorderBrush" Value="#1F2533"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontFamily" Value="Segoe UI Variable Display, Segoe UI, sans-serif"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1E2330"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#293044"/>
                                <Setter Property="Foreground" Value="#C8CFDD"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1A1F35"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══════════════════════════════════════
             COLLECTION PILL BUTTON
        ═══════════════════════════════════════ -->
        <Style x:Key="PillButton" TargetType="Button">
            <Setter Property="Background" Value="#181C25"/>
            <Setter Property="Foreground" Value="#8892A4"/>
            <Setter Property="BorderBrush" Value="#1F2533"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="12.5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontFamily" Value="Segoe UI Variable Display, Segoe UI, sans-serif"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="20"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1C203A"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#6366F1"/>
                                <Setter Property="Foreground" Value="#818CF8"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1E2245"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══════════════════════════════════════
             SEARCH BOX STYLE
        ═══════════════════════════════════════ -->
        <Style x:Key="SearchBoxStyle" TargetType="TextBox">
            <Setter Property="Background" Value="#181C25"/>
            <Setter Property="Foreground" Value="#F0F2F8"/>
            <Setter Property="CaretBrush" Value="#6366F1"/>
            <Setter Property="BorderBrush" Value="#1F2533"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="44,0,16,0"/>
            <Setter Property="FontFamily" Value="Segoe UI Variable Display, Segoe UI, sans-serif"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                            <Grid>
                                <!-- Search icon placeholder (unicode) -->
                                <TextBlock Text="⌕"
                                           FontSize="18"
                                           Foreground="#4A5568"
                                           VerticalAlignment="Center"
                                           Margin="14,0,0,0"
                                           IsHitTestVisible="False"/>
                                <ScrollViewer x:Name="PART_ContentHost"
                                              Margin="{TemplateBinding Padding}"
                                              VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#6366F1"/>
                                <Setter TargetName="Bd" Property="Background" Value="#1C2030"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#293044"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══════════════════════════════════════
             LISTBOX STYLE (no selection chrome)
        ═══════════════════════════════════════ -->
        <Style x:Key="CleanListBox" TargetType="ListBox">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Padding" Value="0"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <ContentPresenter/>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══════════════════════════════════════
             SCROLLBAR STYLE — thin & minimal
        ═══════════════════════════════════════ -->
        <Style TargetType="ScrollBar">
            <Setter Property="Width" Value="5"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid>
                            <Track x:Name="PART_Track" IsDirectionReversed="True">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Opacity="0" Height="0"/>
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border Background="#293044" CornerRadius="3" Margin="1"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Opacity="0" Height="0"/>
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <!-- ═══════════════════════════════════════════════════
         ROOT LAYOUT  — Sidebar | Main content
    ═══════════════════════════════════════════════════ -->
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="228"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ╔══════════════════════════════╗
             ║         SIDEBAR              ║
             ╚══════════════════════════════╝ -->
        <Border Grid.Column="0"
                Background="{StaticResource BgSurface}"
                BorderBrush="{StaticResource BorderSubtle}"
                BorderThickness="0,0,1,0">
            <DockPanel>

                <!-- App Logo / Brand -->
                <Border DockPanel.Dock="Top"
                        Padding="18,22,18,16"
                        BorderBrush="{StaticResource BorderSubtle}"
                        BorderThickness="0,0,0,1">
                    <StackPanel Orientation="Horizontal">
                        <!-- Logo glyph -->
                        <Border Width="32" Height="32"
                                Background="#6366F1"
                                CornerRadius="9">
                            <TextBlock Text="S"
                                       FontSize="17"
                                       FontWeight="Bold"
                                       Foreground="White"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Margin="10,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="ScreenMemory"
                                       FontSize="13.5"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimary}"/>
                            <TextBlock Text="AI"
                                       FontSize="10"
                                       Foreground="{StaticResource AccentGlow}"
                                       Margin="0,-1,0,0"
                                       FontWeight="SemiBold"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Status pill at bottom -->
                <Border DockPanel.Dock="Bottom"
                        Padding="18,14"
                        BorderBrush="{StaticResource BorderSubtle}"
                        BorderThickness="0,1,0,0">
                    <StackPanel>
                        <!-- Settings button -->
                        <Button Content="⚙  Settings"
                                Style="{StaticResource NavButton}"
                                Click="Settings_Click"
                                Margin="0,0,0,4"/>
                        <!-- Status indicator -->
                        <Border Background="#0D1A13"
                                BorderBrush="#1A3028"
                                BorderThickness="1"
                                CornerRadius="6"
                                Padding="10,7">
                            <StackPanel Orientation="Horizontal">
                                <Ellipse Width="7" Height="7" Fill="#10B981" Margin="0,0,7,0" VerticalAlignment="Center"/>
                                <TextBlock x:Name="StatusText"
                                           Text="Ready"
                                           FontSize="11.5"
                                           Foreground="#4ADE80"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- Nav Items -->
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="10,14">
                    <StackPanel>

                        <!-- Section label -->
                        <TextBlock Text="WORKSPACE"
                                   FontSize="9.5"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextMuted}"
                                   Margin="12,4,0,8"
                                   />

                        <Button Content="⌂  Home"
                                Style="{StaticResource NavButton}"
                                Click="Home_Click"/>
                        <Button Content="◷  Recent"
                                Style="{StaticResource NavButton}"
                                Click="Recent_Click"/>

                        <!-- Divider -->
                        <Border Height="1" Background="{StaticResource BorderSubtle}" Margin="12,12"/>

                        <!-- Section label -->
                        <TextBlock Text="COLLECTIONS"
                                   FontSize="9.5"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextMuted}"
                                   Margin="12,0,0,8"
                                   />

                        <Button Content="⊞  Invoices"
                                Style="{StaticResource NavButton}"
                                Click="Invoices_Click"/>
                        <Button Content="⚠  Errors"
                                Style="{StaticResource NavButton}"
                                Click="Errors_Click"/>
                        <Button Content="&lt;/&gt;  Code Snippets"
                                Style="{StaticResource NavButton}"
                                Click="CodeSnippets_Click"/>
                        <Button Content="◎  Conversations"
                                Style="{StaticResource NavButton}"
                                Click="Conversations_Click"/>

                        <!-- Divider -->
                        <Border Height="1" Background="{StaticResource BorderSubtle}" Margin="12,12"/>

                        <Button Content="♡  Favorites"
                                Style="{StaticResource NavButton}"
                                Click="Favorites_Click"/>

                    </StackPanel>
                </ScrollViewer>
            </DockPanel>
        </Border>

        <!-- ╔══════════════════════════════════════════╗
             ║              MAIN CONTENT                ║
             ╚══════════════════════════════════════════╝ -->
        <DockPanel Grid.Column="1">

            <!-- ── TOP BAR ── -->
            <Border DockPanel.Dock="Top"
                    Background="{StaticResource BgSurface}"
                    BorderBrush="{StaticResource BorderSubtle}"
                    BorderThickness="0,0,0,1"
                    Padding="24,14">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Search field -->
                    <TextBox x:Name="SearchBox"
                             Grid.Column="0"
                             Height="42"
                             Style="{StaticResource SearchBoxStyle}"
                             TextChanged="SearchBox_TextChanged"
                             ToolTip="Search screenshots — try: Stripe receipt, terminal error, invoice last week"/>

                    <!-- Action buttons -->
                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                Margin="12,0,0,0">
                        <Button Content="Index Now"
                                Style="{StaticResource PrimaryButton}"
                                Width="110"
                                Height="42"
                                Padding="0"
                                Click="IndexNow_Click"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ── SCROLL CONTENT ── -->
            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          Padding="28,28,28,28"
                          Background="{StaticResource BgBase}">
                <Grid>

                    <!-- ════════════════════════════════
                         HOME DASHBOARD
                    ════════════════════════════════ -->
                    <StackPanel x:Name="HomeDashboardPanel">

                        <!-- Page heading -->
                        <StackPanel Margin="0,0,0,28">
                            <TextBlock Text="What are you looking for?"
                                       FontSize="26"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimary}"/>
                            <TextBlock Text="Search across every indexed screenshot. Hint: try &quot;Stripe receipt&quot; or &quot;terminal error&quot;."
                                       FontSize="13.5"
                                       Foreground="{StaticResource TextSecondary}"
                                       Margin="0,6,0,0"/>
                        </StackPanel>

                        <!-- ── STATS ROW ── -->
                        <Grid Margin="0,0,0,28">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Card: Imported -->
                            <Border Grid.Column="0"
                                    Background="{StaticResource BgCard}"
                                    BorderBrush="{StaticResource BorderSubtle}"
                                    BorderThickness="1"
                                    CornerRadius="12"
                                    Padding="20,18">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="8"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="6"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <!-- Accent dot -->
                                    <Ellipse Grid.Row="0" Width="8" Height="8"
                                             Fill="#6366F1" HorizontalAlignment="Left"/>
                                    <TextBlock x:Name="ImportedCountText"
                                               Grid.Row="2"
                                               Text="0"
                                               FontSize="36"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource TextPrimary}"/>
                                    <TextBlock Grid.Row="4"
                                               Text="Screenshots Imported"
                                               FontSize="12"
                                               Foreground="{StaticResource TextMuted}"/>
                                </Grid>
                            </Border>

                            <!-- Card: OCR Ready -->
                            <Border Grid.Column="2"
                                    Background="{StaticResource BgCard}"
                                    BorderBrush="{StaticResource BorderSubtle}"
                                    BorderThickness="1"
                                    CornerRadius="12"
                                    Padding="20,18">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="8"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="6"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Ellipse Grid.Row="0" Width="8" Height="8"
                                             Fill="#0EA5E9" HorizontalAlignment="Left"/>
                                    <TextBlock x:Name="OcrReadyCountText"
                                               Grid.Row="2"
                                               Text="0"
                                               FontSize="36"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource TextPrimary}"/>
                                    <TextBlock Grid.Row="4"
                                               Text="OCR Ready"
                                               FontSize="12"
                                               Foreground="{StaticResource TextMuted}"/>
                                </Grid>
                            </Border>

                            <!-- Card: AI Tagged -->
                            <Border Grid.Column="4"
                                    Background="{StaticResource BgCard}"
                                    BorderBrush="{StaticResource BorderSubtle}"
                                    BorderThickness="1"
                                    CornerRadius="12"
                                    Padding="20,18">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="8"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="6"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Ellipse Grid.Row="0" Width="8" Height="8"
                                             Fill="#10B981" HorizontalAlignment="Left"/>
                                    <TextBlock x:Name="AiTaggedCountText"
                                               Grid.Row="2"
                                               Text="0"
                                               FontSize="36"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource TextPrimary}"/>
                                    <TextBlock Grid.Row="4"
                                               Text="AI Tagged"
                                               FontSize="12"
                                               Foreground="{StaticResource TextMuted}"/>
                                </Grid>
                            </Border>
                        </Grid>

                        <!-- ── SMART COLLECTIONS ── -->
                        <TextBlock Text="Smart Collections"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimary}"
                                   Margin="0,0,0,12"/>
                        <WrapPanel Margin="0,0,0,32">
                            <Button Content="Invoices"
                                    Style="{StaticResource PillButton}"
                                    Height="32"
                                    Padding="16,0"
                                    Margin="0,0,8,8"
                                    Click="Invoices_Click"/>
                            <Button Content="Errors"
                                    Style="{StaticResource PillButton}"
                                    Height="32"
                                    Padding="16,0"
                                    Margin="0,0,8,8"
                                    Click="Errors_Click"/>
                            <Button Content="Code Snippets"
                                    Style="{StaticResource PillButton}"
                                    Height="32"
                                    Padding="16,0"
                                    Margin="0,0,8,8"
                                    Click="CodeSnippets_Click"/>
                            <Button Content="Conversations"
                                    Style="{StaticResource PillButton}"
                                    Height="32"
                                    Padding="16,0"
                                    Margin="0,0,8,8"
                                    Click="Conversations_Click"/>
                            <Button Content="Favorites"
                                    Style="{StaticResource PillButton}"
                                    Height="32"
                                    Padding="16,0"
                                    Margin="0,0,8,8"
                                    Click="Favorites_Click"/>
                        </WrapPanel>

                        <!-- ── RECENT SCREENSHOTS ── -->
                        <Grid Margin="0,0,0,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="Recent Screenshots"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimary}"
                                       VerticalAlignment="Center"/>
                            <Button Grid.Column="1"
                                    Content="View all →"
                                    Style="{StaticResource NavButton}"
                                    Foreground="{StaticResource AccentGlow}"
                                    FontSize="12"
                                    Click="Recent_Click"/>
                        </Grid>

                        <ListBox x:Name="RecentScreenshotsList"
                                 Style="{StaticResource CleanListBox}">
                            <ListBox.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel/>
                                </ItemsPanelTemplate>
                            </ListBox.ItemsPanel>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Width="210"
                                            Margin="0,0,14,14"
                                            Background="{StaticResource BgCard}"
                                            BorderBrush="{StaticResource BorderSubtle}"
                                            BorderThickness="1"
                                            CornerRadius="12"
                                            Cursor="Hand">
                                        <StackPanel>
                                            <Border Height="130"
                                                    Background="#0F1219"
                                                    CornerRadius="11,11,0,0">
                                                <Image Source="{Binding ThumbnailPath}"
                                                       Stretch="UniformToFill"
                                                       RenderOptions.BitmapScalingMode="HighQuality"/>
                                            </Border>
                                            <StackPanel Margin="12,10,12,12">
                                                <TextBlock Text="{Binding FileName}"
                                                           FontSize="12"
                                                           FontWeight="SemiBold"
                                                           Foreground="{StaticResource TextSecondary}"
                                                           TextTrimming="CharacterEllipsis"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                    </StackPanel>

                    <!-- ════════════════════════════════
                         RESULTS PANEL
                    ════════════════════════════════ -->
                    <StackPanel x:Name="ResultsPanel" Visibility="Collapsed">

                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock x:Name="ResultsTitleText"
                                           Text="Results"
                                           FontSize="24"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource TextPrimary}"/>
                                <TextBlock x:Name="ResultsMetaText"
                                           Text="0 result(s)"
                                           FontSize="13"
                                           Foreground="{StaticResource TextSecondary}"
                                           Margin="0,4,0,0"/>
                            </StackPanel>
                            <Button Grid.Column="1"
                                    Content="← Back to Home"
                                    Style="{StaticResource GhostButton}"
                                    Height="36"
                                    Padding="14,0"
                                    VerticalAlignment="Top"
                                    Click="Home_Click"/>
                        </Grid>

                        <!-- Thin accent line -->
                        <Border Height="1"
                                Background="#6366F1"
                                Width="40"
                                HorizontalAlignment="Left"
                                Margin="0,10,0,20"
                                Opacity="0.7"/>

                        <ListBox x:Name="ResultsList"
                                 Style="{StaticResource CleanListBox}">
                            <ListBox.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel/>
                                </ItemsPanelTemplate>
                            </ListBox.ItemsPanel>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Width="220"
                                            Margin="0,0,14,14"
                                            Background="{StaticResource BgCard}"
                                            BorderBrush="{StaticResource BorderSubtle}"
                                            BorderThickness="1"
                                            CornerRadius="12"
                                            Cursor="Hand">
                                        <StackPanel>
                                            <Border Height="140"
                                                    Background="#0F1219"
                                                    CornerRadius="11,11,0,0">
                                                <Image Source="{Binding ThumbnailPath}"
                                                       Stretch="UniformToFill"
                                                       RenderOptions.BitmapScalingMode="HighQuality"/>
                                            </Border>
                                            <StackPanel Margin="12,10,12,12">
                                                <TextBlock Text="{Binding FileName}"
                                                           FontSize="12"
                                                           FontWeight="SemiBold"
                                                           Foreground="{StaticResource TextSecondary}"
                                                           TextTrimming="CharacterEllipsis"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </StackPanel>

                </Grid>
            </ScrollViewer>
        </DockPanel>
    </Grid>
</Window>
