<Window x:Class="ScreenMemory.AI.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ScreenMemory AI"
        Icon="pack://application:,,,/Assets/AppIcon.ico"
        Height="760"
        Width="1200"
        MinHeight="600"
        MinWidth="920"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="CanResize"
        FontFamily="Segoe UI Variable Display, Segoe UI, sans-serif"
        Background="#0D0F14">

    <Window.Resources>

        <!-- ══════════════════════════════
             PALETTE
        ══════════════════════════════ -->
        <SolidColorBrush x:Key="BgBase"         Color="#0D0F14"/>
        <SolidColorBrush x:Key="BgSurface"      Color="#13161D"/>
        <SolidColorBrush x:Key="BgCard"         Color="#181C25"/>
        <SolidColorBrush x:Key="BorderSubtle"   Color="#1F2533"/>
        <SolidColorBrush x:Key="BorderMed"      Color="#293044"/>
        <SolidColorBrush x:Key="AccentPrimary"  Color="#6366F1"/>
        <SolidColorBrush x:Key="AccentGlow"     Color="#818CF8"/>
        <SolidColorBrush x:Key="AccentMuted"    Color="#1E2040"/>
        <SolidColorBrush x:Key="TextPrimary"    Color="#F0F2F8"/>
        <SolidColorBrush x:Key="TextSecondary"  Color="#8892A4"/>
        <SolidColorBrush x:Key="TextMuted"      Color="#4A5568"/>
        <SolidColorBrush x:Key="StatusGreen"    Color="#10B981"/>

        <!-- ══════════════════════════════
             NAV BUTTON
        ══════════════════════════════ -->
        <Style x:Key="NavButton" TargetType="Button">
            <Setter Property="Background"              Value="Transparent"/>
            <Setter Property="BorderThickness"         Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding"                 Value="10,8"/>
            <Setter Property="Margin"                  Value="0,1,0,0"/>
            <Setter Property="Cursor"                  Value="Hand"/>
            <Setter Property="Foreground"              Value="#8892A4"/>
            <Setter Property="FontSize"                Value="13"/>
            <Setter Property="FontFamily"              Value="Segoe UI Variable Display, Segoe UI, sans-serif"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="7"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1A1F2E"/>
                                <Setter Property="Foreground" Value="#C8CFDD"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1E2340"/>
                                <Setter Property="Foreground" Value="#6366F1"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="NavButtonActive" TargetType="Button" BasedOn="{StaticResource NavButton}">
            <Setter Property="Background" Value="#1C203A"/>
            <Setter Property="Foreground" Value="#818CF8"/>
        </Style>

        <!-- ══════════════════════════════
             PRIMARY BUTTON
        ══════════════════════════════ -->
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background"    Value="#6366F1"/>
            <Setter Property="Foreground"    Value="#FFFFFF"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize"      Value="13"/>
            <Setter Property="FontWeight"    Value="SemiBold"/>
            <Setter Property="Cursor"        Value="Hand"/>
            <Setter Property="FontFamily"    Value="Segoe UI Variable Display, Segoe UI, sans-serif"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#7577F3"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#4F51C8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ══════════════════════════════
             GHOST BUTTON
        ══════════════════════════════ -->
        <Style x:Key="GhostButton" TargetType="Button">
            <Setter Property="Background"    Value="#1A1F2E"/>
            <Setter Property="Foreground"    Value="#8892A4"/>
            <Setter Property="BorderBrush"   Value="#1F2533"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize"      Value="12.5"/>
            <Setter Property="Cursor"        Value="Hand"/>
            <Setter Property="FontFamily"    Value="Segoe UI Variable Display, Segoe UI, sans-serif"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="7"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1E2330"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#293044"/>
                                <Setter Property="Foreground" Value="#C8CFDD"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1A1F35"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ══════════════════════════════
             PILL BUTTON
        ══════════════════════════════ -->
        <Style x:Key="PillButton" TargetType="Button">
            <Setter Property="Background"    Value="#181C25"/>
            <Setter Property="Foreground"    Value="#8892A4"/>
            <Setter Property="BorderBrush"   Value="#1F2533"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize"      Value="12"/>
            <Setter Property="Cursor"        Value="Hand"/>
            <Setter Property="FontFamily"    Value="Segoe UI Variable Display, Segoe UI, sans-serif"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="20"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1C203A"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#6366F1"/>
                                <Setter Property="Foreground" Value="#818CF8"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1E2245"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ══════════════════════════════
             SEARCH BOX
        ══════════════════════════════ -->
        <Style x:Key="SearchBoxStyle" TargetType="TextBox">
            <Setter Property="Background"           Value="#181C25"/>
            <Setter Property="Foreground"           Value="#F0F2F8"/>
            <Setter Property="CaretBrush"           Value="#6366F1"/>
            <Setter Property="BorderBrush"          Value="#1F2533"/>
            <Setter Property="BorderThickness"      Value="1"/>
            <Setter Property="FontSize"             Value="13.5"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding"              Value="40,0,14,0"/>
            <Setter Property="FontFamily"           Value="Segoe UI Variable Display, Segoe UI, sans-serif"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="9">
                            <Grid>
                                <TextBlock Text="⌕"
                                           FontSize="17"
                                           Foreground="#4A5568"
                                           VerticalAlignment="Center"
                                           Margin="13,0,0,0"
                                           IsHitTestVisible="False"/>
                                <ScrollViewer x:Name="PART_ContentHost"
                                              Margin="{TemplateBinding Padding}"
                                              VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#6366F1"/>
                                <Setter TargetName="Bd" Property="Background" Value="#1C2030"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#293044"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ══════════════════════════════
             SCROLLBAR — ultra-thin
        ══════════════════════════════ -->
        <Style TargetType="ScrollBar">
            <Setter Property="Width"      Value="4"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid>
                            <Track x:Name="PART_Track" IsDirectionReversed="True">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Opacity="0" Height="0"/>
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border Background="#293044" CornerRadius="2" Margin="1"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Opacity="0" Height="0"/>
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <DataTemplate x:Key="ScreenshotCardTemplate">
            <Border Width="168" Margin="0,0,10,10"
                    CornerRadius="10" Cursor="Hand"
                    MouseLeftButtonDown="ScreenshotCard_MouseLeftButtonDown">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Background" Value="#181C25"/>
                        <Setter Property="BorderBrush" Value="#1F2533"/>
                        <Setter Property="BorderThickness" Value="1"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                <Setter Property="BorderBrush" Value="#6366F1"/>
                                <Setter Property="BorderThickness" Value="1.5"/>
                                <Setter Property="Background" Value="#1C2036"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <StackPanel>
                    <Border Height="102" Background="#0F1219" CornerRadius="9,9,0,0" ClipToBounds="True">
                        <Image Source="{Binding ThumbnailPath}"
                               Stretch="UniformToFill"
                               RenderOptions.BitmapScalingMode="LowQuality"/>
                    </Border>
                    <StackPanel Margin="9,7,9,9">
                        <TextBlock Text="{Binding FileName}"
                                   FontSize="11" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextSecondary}"
                                   TextTrimming="CharacterEllipsis"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </DataTemplate>

    </Window.Resources>

    <!-- ══════════════════════════════════════════════
         ROOT — Sidebar | Main | [Preview slide-in]
    ══════════════════════════════════════════════ -->
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition x:Name="PreviewColumn" Width="0"/>
        </Grid.ColumnDefinitions>

        <!-- ╔══════════════════╗
             ║    SIDEBAR       ║
             ╚══════════════════╝ -->
        <Border Grid.Column="0"
                Background="{StaticResource BgSurface}"
                BorderBrush="{StaticResource BorderSubtle}"
                BorderThickness="0,0,1,0">
            <DockPanel>

                <!-- Brand -->
                <Border DockPanel.Dock="Top"
                        Padding="16,18,16,14"
                        BorderBrush="{StaticResource BorderSubtle}"
                        BorderThickness="0,0,0,1">
                    <StackPanel Orientation="Horizontal">
                        <Border Width="30" Height="30" CornerRadius="8" ClipToBounds="True">
                            <Image Source="pack://application:,,,/Assets/AppIcon.ico"
                                   Stretch="UniformToFill"/>
                        </Border>
                        <StackPanel Margin="9,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="ScreenMemory"
                                       FontSize="13" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimary}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Bottom: settings + status -->
                <Border DockPanel.Dock="Bottom"
                        Padding="12,12"
                        BorderBrush="{StaticResource BorderSubtle}"
                        BorderThickness="0,1,0,0">
                    <StackPanel>
                        <Button Content="⚙  Settings"
                                Style="{StaticResource NavButton}"
                                Click="Settings_Click"
                                Margin="0,0,0,8"/>
                        <Border Background="#0D1A13"
                                BorderBrush="#1A3028"
                                BorderThickness="1"
                                CornerRadius="6"
                                Padding="9,6">
                            <StackPanel Orientation="Horizontal">
                                <Ellipse Width="6" Height="6" Fill="#10B981" Margin="0,0,7,0" VerticalAlignment="Center"/>
                                <TextBlock x:Name="StatusText"
                                           Text="Ready"
                                           FontSize="11"
                                           Foreground="#4ADE80"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- Nav -->
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="8,12">
                    <StackPanel>
                        <TextBlock Text="WORKSPACE"
                                   FontSize="9" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextMuted}"
                                   Margin="10,2,0,6"/>

                        <Button Content="⌂  Home"   Style="{StaticResource NavButton}" Click="Home_Click"/>
                        <Button Content="◷  Recent" Style="{StaticResource NavButton}" Click="Recent_Click"/>

                        <Border Height="1" Background="{StaticResource BorderSubtle}" Margin="10,10"/>

                        <TextBlock Text="COLLECTIONS"
                                   FontSize="9" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextMuted}"
                                   Margin="10,0,0,6"/>

                        <Button Content="⊞  Invoices"     Style="{StaticResource NavButton}" Click="Invoices_Click"/>
                        <Button Content="⚠  Errors"        Style="{StaticResource NavButton}" Click="Errors_Click"/>
                        <Button Content="&lt;/&gt;  Code"  Style="{StaticResource NavButton}" Click="CodeSnippets_Click"/>
                        <Button Content="◎  Conversations" Style="{StaticResource NavButton}" Click="Conversations_Click"/>

                        <Border Height="1" Background="{StaticResource BorderSubtle}" Margin="10,10"/>

                        <Button Content="♡  Favorites" Style="{StaticResource NavButton}" Click="Favorites_Click"/>
                    </StackPanel>
                </ScrollViewer>
            </DockPanel>
        </Border>

        <!-- ╔══════════════════════════════╗
             ║         MAIN CONTENT         ║
             ╚══════════════════════════════╝ -->
        <DockPanel Grid.Column="1">

            <!-- TOP BAR -->
            <Border DockPanel.Dock="Top"
                    Background="{StaticResource BgSurface}"
                    BorderBrush="{StaticResource BorderSubtle}"
                    BorderThickness="0,0,0,1"
                    Padding="20,11"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBox x:Name="SearchBox"
                             Grid.Column="0"
                             Height="38"
                             Style="{StaticResource SearchBoxStyle}"
                             TextChanged="SearchBox_TextChanged"
                             ToolTip="Try: Stripe receipt, terminal error, invoice"/>

                    <Button Content="Index Now"
                            Grid.Column="1"
                            Style="{StaticResource PrimaryButton}"
                            Width="106" Height="38"
                            Padding="0"
                            Margin="10,0,0,0"
                            Click="IndexNow_Click"/>
                    <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="12,0,0,0" VerticalAlignment="Center">
                        <Button Content="—" Width="34" Height="30" Style="{StaticResource GhostButton}" Padding="0" Margin="0,0,6,0" Click="WindowMinimize_Click"/>
                        <Button Content="▢" Width="34" Height="30" Style="{StaticResource GhostButton}" Padding="0" Margin="0,0,6,0" Click="WindowMaximizeRestore_Click"/>
                        <Button Content="✕" Width="34" Height="30" Style="{StaticResource GhostButton}" Padding="0" Click="WindowClose_Click"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- CONTENT AREA -->
            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          Padding="24,22,20,24"
                          Background="{StaticResource BgBase}">
                <Grid>

                    <!-- ══════════════════════════
                         HOME DASHBOARD
                    ══════════════════════════ -->
                    <StackPanel x:Name="HomeDashboardPanel">

                        <!-- Page heading -->
                        <StackPanel Margin="0,0,0,20">
                            <TextBlock Text="Your Screenshot Memory"
                                       FontSize="21" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimary}"/>
                            <TextBlock Text="Search, browse, and rediscover everything you've captured."
                                       FontSize="12.5"
                                       Foreground="{StaticResource TextSecondary}"
                                       Margin="0,4,0,0"/>
                        </StackPanel>

                        <!-- ── COMPACT STAT STRIP ── -->
                        <Border Background="{StaticResource BgCard}"
                                BorderBrush="{StaticResource BorderSubtle}"
                                BorderThickness="1"
                                CornerRadius="10"
                                Padding="0"
                                Margin="0,0,0,22">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="1"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="1"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <!-- Imported -->
                                <StackPanel Grid.Column="0" Margin="20,14" Orientation="Horizontal">
                                    <Border Width="6" Background="#6366F1" CornerRadius="3" Margin="0,0,12,0"/>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock x:Name="ImportedCountText"
                                                   Text="0"
                                                   FontSize="22" FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextPrimary}"/>
                                        <TextBlock Text="Imported"
                                                   FontSize="11"
                                                   Foreground="{StaticResource TextMuted}"
                                                   Margin="0,1,0,0"/>
                                    </StackPanel>
                                </StackPanel>

                                <!-- Divider -->
                                <Border Grid.Column="1" Background="{StaticResource BorderSubtle}"/>

                                <!-- OCR Ready -->
                                <StackPanel Grid.Column="2" Margin="20,14" Orientation="Horizontal">
                                    <Border Width="6" Background="#0EA5E9" CornerRadius="3" Margin="0,0,12,0"/>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock x:Name="OcrReadyCountText"
                                                   Text="0"
                                                   FontSize="22" FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextPrimary}"/>
                                        <TextBlock Text="OCR Ready"
                                                   FontSize="11"
                                                   Foreground="{StaticResource TextMuted}"
                                                   Margin="0,1,0,0"/>
                                    </StackPanel>
                                </StackPanel>

                                <!-- Divider -->
                                <Border Grid.Column="3" Background="{StaticResource BorderSubtle}"/>

                                <!-- AI Tagged -->
                                <StackPanel Grid.Column="4" Margin="20,14" Orientation="Horizontal">
                                    <Border Width="6" Background="#10B981" CornerRadius="3" Margin="0,0,12,0"/>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock x:Name="AiTaggedCountText"
                                                   Text="0"
                                                   FontSize="22" FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextPrimary}"/>
                                        <TextBlock Text="AI Tagged"
                                                   FontSize="11"
                                                   Foreground="{StaticResource TextMuted}"
                                                   Margin="0,1,0,0"/>
                                    </StackPanel>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- ── SMART COLLECTIONS ── -->
                        <TextBlock Text="Collections"
                                   FontSize="12.5" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextSecondary}"
                                   Margin="0,0,0,10"/>
                        <WrapPanel Margin="0,0,0,26">
                            <Button Content="Invoices"     Style="{StaticResource PillButton}" Height="28" Padding="14,0" Margin="0,0,7,7" Click="Invoices_Click"/>
                            <Button Content="Errors"       Style="{StaticResource PillButton}" Height="28" Padding="14,0" Margin="0,0,7,7" Click="Errors_Click"/>
                            <Button Content="Code Snippets" Style="{StaticResource PillButton}" Height="28" Padding="14,0" Margin="0,0,7,7" Click="CodeSnippets_Click"/>
                            <Button Content="Conversations" Style="{StaticResource PillButton}" Height="28" Padding="14,0" Margin="0,0,7,7" Click="Conversations_Click"/>
                            <Button Content="Favorites"    Style="{StaticResource PillButton}" Height="28" Padding="14,0" Margin="0,0,7,7" Click="Favorites_Click"/>
                        </WrapPanel>

                        <!-- ── RECENT SCREENSHOTS ── -->
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="Recent Screenshots"
                                       FontSize="12.5" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextSecondary}"
                                       VerticalAlignment="Center"/>
                            <Button Grid.Column="1"
                                    Content="View all →"
                                    Style="{StaticResource NavButton}"
                                    Foreground="{StaticResource AccentGlow}"
                                    FontSize="12"
                                    Click="Recent_Click"/>
                        </Grid>

                        <StackPanel x:Name="RecentTodaySection" Margin="0,0,0,8">
                            <TextBlock Text="Today" FontSize="11.5" FontWeight="SemiBold" Foreground="{StaticResource TextMuted}" Margin="0,0,0,6"/>
                            <ItemsControl x:Name="RecentTodayList" ItemTemplate="{StaticResource ScreenshotCardTemplate}">
                                <ItemsControl.ItemsPanel><ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                            </ItemsControl>
                        </StackPanel>

                        <StackPanel x:Name="RecentYesterdaySection" Margin="0,0,0,8">
                            <TextBlock Text="Yesterday" FontSize="11.5" FontWeight="SemiBold" Foreground="{StaticResource TextMuted}" Margin="0,0,0,6"/>
                            <ItemsControl x:Name="RecentYesterdayList" ItemTemplate="{StaticResource ScreenshotCardTemplate}">
                                <ItemsControl.ItemsPanel><ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                            </ItemsControl>
                        </StackPanel>

                        <StackPanel x:Name="RecentWeekSection" Margin="0,0,0,8">
                            <TextBlock Text="This Week" FontSize="11.5" FontWeight="SemiBold" Foreground="{StaticResource TextMuted}" Margin="0,0,0,6"/>
                            <ItemsControl x:Name="RecentWeekList" ItemTemplate="{StaticResource ScreenshotCardTemplate}">
                                <ItemsControl.ItemsPanel><ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                            </ItemsControl>
                        </StackPanel>

                        <StackPanel x:Name="RecentOlderSection">
                            <TextBlock Text="Older" FontSize="11.5" FontWeight="SemiBold" Foreground="{StaticResource TextMuted}" Margin="0,0,0,6"/>
                            <ItemsControl x:Name="RecentOlderList" ItemTemplate="{StaticResource ScreenshotCardTemplate}">
                                <ItemsControl.ItemsPanel><ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                            </ItemsControl>
                        </StackPanel>

                    </StackPanel>

                    <!-- ══════════════════════════
                         RESULTS PANEL
                    ══════════════════════════ -->
                    <StackPanel x:Name="ResultsPanel" Visibility="Collapsed">

                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock x:Name="ResultsTitleText"
                                           Text="Results"
                                           FontSize="21" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextPrimary}"/>
                                <TextBlock x:Name="ResultsMetaText"
                                           Text="0 result(s)"
                                           FontSize="12.5"
                                           Foreground="{StaticResource TextSecondary}"
                                           Margin="0,3,0,0"/>
                            </StackPanel>
                            <Button Grid.Column="1"
                                    Content="← Home"
                                    Style="{StaticResource GhostButton}"
                                    Height="34" Padding="14,0"
                                    VerticalAlignment="Top"
                                    Click="Home_Click"/>
                        </Grid>

                        <Border Height="2" Width="32" HorizontalAlignment="Left"
                                Background="#6366F1" CornerRadius="1"
                                Margin="0,10,0,18" Opacity="0.8"/>

                        <ItemsControl x:Name="ResultsList" ItemTemplate="{StaticResource ScreenshotCardTemplate}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                        </ItemsControl>

                    </StackPanel>

                </Grid>
            </ScrollViewer>

        </DockPanel>

        <!-- ╔══════════════════════════════════╗
             ║   SIDE PREVIEW PANEL             ║
             ║   Hidden by default.             ║
             ║   Shown only on card click.      ║
             ╚══════════════════════════════════╝ -->
        <Border x:Name="PreviewPanel"
                Grid.Column="2"
                Background="{StaticResource BgSurface}"
                BorderBrush="{StaticResource BorderSubtle}"
                BorderThickness="1,0,0,0"
                Visibility="Collapsed">
            <DockPanel>

                <!-- Header -->
                <Border DockPanel.Dock="Top"
                        Padding="16,13,12,13"
                        BorderBrush="{StaticResource BorderSubtle}"
                        BorderThickness="0,0,0,1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   Text="Preview"
                                   FontSize="14" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimary}"
                                   VerticalAlignment="Center"/>
                        <Button Grid.Column="1"
                                Content="✕"
                                Width="28" Height="28"
                                Style="{StaticResource GhostButton}"
                                Padding="0"
                                Click="PreviewClose_Click"/>
                    </Grid>
                </Border>

                <!-- Action row -->
                <Border DockPanel.Dock="Bottom"
                        Padding="14,12"
                        BorderBrush="{StaticResource BorderSubtle}"
                        BorderThickness="0,1,0,0">
                    <WrapPanel>
                        <Button x:Name="PreviewOpenImageButton"
                                Content="Open"
                                Style="{StaticResource PrimaryButton}"
                                Height="32" Padding="14,0"
                                Margin="0,0,7,0"
                                Click="PreviewOpenImage_Click"/>
                        <Button x:Name="PreviewRevealButton"
                                Content="Reveal"
                                Style="{StaticResource GhostButton}"
                                Height="32" Padding="12,0"
                                Margin="0,0,7,0"
                                Click="PreviewReveal_Click"/>
                        <Button Content="Copy Path"
                                Style="{StaticResource GhostButton}"
                                Height="32" Padding="12,0"
                                Click="PreviewCopyPath_Click"/>
                    </WrapPanel>
                </Border>

                <!-- Detail scroll -->
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="14,0">
                    <StackPanel Margin="0,14,0,0">

                        <!-- Image preview area -->
                        <Border Height="190"
                                Background="#0F1219"
                                CornerRadius="9"
                                Margin="0,0,0,16"
                                ClipToBounds="True">
                            <Grid>
                                <Image x:Name="PreviewImage" Stretch="Uniform"/>
                                <TextBlock x:Name="PreviewPlaceholderText"
                                           Text="Loading…"
                                           Foreground="{StaticResource TextMuted}"
                                           FontSize="12"
                                           VerticalAlignment="Center"
                                           HorizontalAlignment="Center"/>
                            </Grid>
                        </Border>

                        <!-- File Name -->
                        <TextBlock Text="FILE NAME"
                                   FontSize="9.5" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextMuted}"
                                   Margin="0,0,0,3"/>
                        <TextBlock x:Name="PreviewFileNameText"
                                   FontSize="12.5"
                                   Foreground="{StaticResource TextPrimary}"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,14"/>

                        <!-- Created -->
                        <TextBlock Text="CREATED"
                                   FontSize="9.5" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextMuted}"
                                   Margin="0,0,0,3"/>
                        <TextBlock x:Name="PreviewCreatedAtText"
                                   FontSize="12.5"
                                   Foreground="{StaticResource TextSecondary}"
                                   Margin="0,0,0,14"/>

                        <!-- File Size -->
                        <TextBlock Text="SIZE"
                                   FontSize="9.5" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextMuted}"
                                   Margin="0,0,0,3"/>
                        <TextBlock x:Name="PreviewFileSizeText"
                                   FontSize="12.5"
                                   Foreground="{StaticResource TextSecondary}"
                                   Margin="0,0,0,14"/>

                        <!-- OCR Status -->
                        <TextBlock Text="OCR STATUS"
                                   FontSize="9.5" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextMuted}"
                                   Margin="0,0,0,3"/>
                        <TextBlock x:Name="PreviewOcrStatusText"
                                   FontSize="12.5"
                                   Foreground="{StaticResource TextSecondary}"
                                   Margin="0,0,0,14"/>

                        <!-- Path -->
                        <TextBlock Text="PATH"
                                   FontSize="9.5" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextMuted}"
                                   Margin="0,0,0,3"/>
                        <TextBlock x:Name="PreviewFilePathText"
                                   FontSize="11"
                                   Foreground="{StaticResource TextMuted}"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,14"/>

                    </StackPanel>
                </ScrollViewer>

            </DockPanel>
        </Border>

    </Grid>
</Window>
