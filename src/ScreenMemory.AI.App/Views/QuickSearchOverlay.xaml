<Window x:Class="ScreenMemory.AI.App.Views.QuickSearchOverlay"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Quick Search"
        Width="760"
        Height="220"
        MinHeight="220"
        MaxHeight="640"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        WindowStartupLocation="CenterScreen"
        KeyDown="Window_KeyDown">

    <Window.Resources>
        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="#E8ECF7"/>
            <Setter Property="Background" Value="#21283A"/>
            <Setter Property="BorderBrush" Value="#303A52"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="11.5"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#2A3350"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#4B5B84"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1B2233"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="#D911141A"
            BorderBrush="#2A2E38"
            BorderThickness="1"
            CornerRadius="16"
            Padding="16"
            MouseLeftButtonDown="Shell_MouseLeftButtonDown">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="10"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="12"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Quick Search"
                           Foreground="#AAB4C8"
                           FontSize="11"
                           VerticalAlignment="Center"/>
                <Border Grid.Column="1"
                        Width="42"
                        Height="4"
                        CornerRadius="2"
                        Background="#3D465B"
                        VerticalAlignment="Center"
                        Margin="0,0,2,0"/>
            </Grid>

            <TextBox x:Name="SearchBox"
                     Grid.Row="2"
                     Height="44"
                     FontSize="16"
                     Padding="14,0"
                     Background="#1A1F2A"
                     Foreground="#F0F2F8"
                     BorderBrush="#2D3342"
                     BorderThickness="1"
                     VerticalContentAlignment="Center"
                     TextChanged="SearchBox_TextChanged"/>

            <ListBox x:Name="ResultsList"
                     Grid.Row="4"
                     Background="Transparent"
                     BorderThickness="0"
                     Foreground="#F0F2F8"
                     SelectionMode="Single"
                     MouseDoubleClick="ResultsList_MouseDoubleClick">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Padding" Value="0"/>
                        <Setter Property="Margin" Value="0,0,0,8"/>
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <Border x:Name="Bd"
                                            Background="#161B25"
                                            BorderBrush="#262D3C"
                                            BorderThickness="1"
                                            CornerRadius="10"
                                            Padding="10">
                                        <ContentPresenter/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="Bd" Property="BorderBrush" Value="#6366F1"/>
                                            <Setter TargetName="Bd" Property="Background" Value="#1D2233"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Border x:Name="ThumbBorder"
                                    Grid.Column="0"
                                    Width="88"
                                    Height="60"
                                    CornerRadius="8"
                                    Background="#0F1219"
                                    ClipToBounds="True">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding ThumbnailPath}" Value="">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding ThumbnailPath}" Value="{x:Null}">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <Image Source="{Binding ThumbnailPath}" Stretch="UniformToFill"/>
                            </Border>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="{Binding FileName}" FontWeight="SemiBold" FontSize="13" TextTrimming="CharacterEllipsis"/>
                                <TextBlock Text="{Binding CreatedAt}" FontSize="10" Foreground="#778196" Margin="0,4,0,0"/>
                            </StackPanel>
                            <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center">
                                <Button Content="Open"
                                        Style="{StaticResource ActionButtonStyle}"
                                        Width="66" Height="30"
                                        Margin="0,0,6,0"
                                        Click="OpenButton_Click"/>
                                <Button Content="Reveal"
                                        Style="{StaticResource ActionButtonStyle}"
                                        Width="70" Height="30"
                                        Click="RevealButton_Click"/>
                            </StackPanel>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Grid>
    </Border>
</Window>
