<Window x:Class="ScreenMemory.AI.App.Views.QuickSearchOverlay"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Quick Search"
        Icon="pack://application:,,,/Assets/AppIcon.ico"
        Width="720"
        Height="104"
        MinHeight="104"
        MaxHeight="620"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        FontFamily="Inter, Segoe UI Variable Display, Segoe UI Variable, Segoe UI, sans-serif"
        SnapsToDevicePixels="True"
        UseLayoutRounding="True"
        KeyDown="Window_KeyDown">

    <Window.Resources>
        <SolidColorBrush x:Key="BackgroundDeep" Color="#0B0C0E"/>
        <SolidColorBrush x:Key="BackgroundPrimary" Color="#0E0E10"/>
        <SolidColorBrush x:Key="BackgroundSecondary" Color="#121317"/>
        <SolidColorBrush x:Key="BackgroundTertiary" Color="#1A1B1F"/>
        <SolidColorBrush x:Key="BackgroundElevated" Color="#1E1F24"/>
        <SolidColorBrush x:Key="BackgroundHover" Color="#292A2E"/>
        <SolidColorBrush x:Key="BorderSubtle" Color="#14FFFFFF"/>
        <SolidColorBrush x:Key="BorderDefault" Color="#26FFFFFF"/>
        <SolidColorBrush x:Key="BorderEmphasis" Color="#3D4459"/>
        <SolidColorBrush x:Key="AccentPrimary" Color="#8B5CF6"/>
        <SolidColorBrush x:Key="AccentGlow" Color="#D0BCFF"/>
        <SolidColorBrush x:Key="AccentSubtle" Color="#1A8B5CF6"/>
        <SolidColorBrush x:Key="TextPrimary" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="TextSecondary" Color="#CBC3D7"/>
        <SolidColorBrush x:Key="TextTertiary" Color="#A1A1AA"/>
        <SolidColorBrush x:Key="TextMuted" Color="#6F687A"/>

        <DropShadowEffect x:Key="OverlayShadow"
                          Color="#000000"
                          BlurRadius="48"
                          ShadowDepth="0"
                          Opacity="0.72"/>

        <DropShadowEffect x:Key="AccentAura"
                          Color="#8B5CF6"
                          BlurRadius="18"
                          ShadowDepth="0"
                          Opacity="0.28"/>

        <Style TargetType="ScrollBar">
            <Setter Property="Width" Value="5"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid>
                            <Track x:Name="PART_Track" IsDirectionReversed="True">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Opacity="0" Height="0"/>
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border Background="{StaticResource BorderEmphasis}" CornerRadius="3" Margin="1"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Opacity="0" Height="0"/>
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ActionBtn" TargetType="Button">
            <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
            <Setter Property="Background" Value="{StaticResource BackgroundTertiary}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderDefault}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="11.5"/>
            <Setter Property="FontWeight" Value="600"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="9"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource AccentSubtle}"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource AccentPrimary}"/>
                                <Setter Property="Foreground" Value="{StaticResource AccentGlow}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource BackgroundElevated}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SearchModeButton" TargetType="Button">
            <Setter Property="Foreground" Value="{StaticResource TextTertiary}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="700"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="MinWidth" Value="60"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="9"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource BackgroundHover}"/>
                                <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
                            </Trigger>
                            <Trigger Property="Tag" Value="Selected">
                                <Setter TargetName="Bd" Property="Background" Value="#2A1C4A"/>
                                <Setter Property="Foreground" Value="{StaticResource AccentGlow}"/>
                                <Setter TargetName="Bd" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect Color="#8B5CF6" BlurRadius="8" ShadowDepth="0" Opacity="0.25"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.45"/>
                                <Setter Property="Foreground" Value="{StaticResource TextMuted}"/>
                                <Setter Property="Cursor" Value="Arrow"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SearchBoxStyle" TargetType="TextBox">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="CaretBrush" Value="{StaticResource AccentPrimary}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="500"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <ScrollViewer x:Name="PART_ContentHost" Margin="0"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="#F216171B"
            BorderBrush="{StaticResource BorderDefault}"
            BorderThickness="1"
            CornerRadius="18"
            MouseLeftButtonDown="Shell_MouseLeftButtonDown"
            SnapsToDevicePixels="True"
            Effect="{StaticResource OverlayShadow}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Height="44" Margin="18,14,18,14" VerticalAlignment="Center">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Width="40"
                        Height="40"
                        CornerRadius="12"
                        Background="{StaticResource AccentSubtle}"
                        BorderBrush="{StaticResource AccentPrimary}"
                        BorderThickness="1"
                        Margin="0,0,12,0"
                        VerticalAlignment="Center">
                    <Border.Effect>
                        <DropShadowEffect Color="#8B5CF6" BlurRadius="12" ShadowDepth="0" Opacity="0.35"/>
                    </Border.Effect>
                    <Viewbox Width="17" Height="17">
                        <Path Data="M15.5 14h-.79l-.28-.27A6.5 6.5 0 1 0 13.73 14l.27.28v.79l5 4.99L20.49 19l-4.99-5zM9.5 14A4.5 4.5 0 1 1 14 9.5 4.5 4.5 0 0 1 9.5 14z"
                              Fill="{StaticResource AccentGlow}"
                              Stretch="Uniform"/>
                    </Viewbox>
                </Border>

                <TextBox x:Name="SearchBox"
                         Grid.Column="1"
                         Style="{StaticResource SearchBoxStyle}"
                         Height="40"
                         VerticalAlignment="Center"
                         GotKeyboardFocus="SearchBox_GotKeyboardFocus"
                         PreviewMouseLeftButtonDown="SearchBox_PreviewMouseLeftButtonDown"
                         TextChanged="SearchBox_TextChanged">
                    <TextBox.Resources>
                        <Style TargetType="TextBox">
                            <Style.Triggers>
                                <Trigger Property="Text" Value="">
                                    <Setter Property="Background">
                                        <Setter.Value>
                                            <VisualBrush AlignmentX="Left" AlignmentY="Center" Stretch="None">
                                                <VisualBrush.Visual>
                                                    <TextBlock Text="Search screenshots..."
                                                               Foreground="{StaticResource TextMuted}"
                                                               FontSize="15"
                                                               FontWeight="500"
                                                               FontFamily="Inter, Segoe UI Variable Display, Segoe UI Variable, Segoe UI, sans-serif"
                                                               Margin="2,0,0,0"/>
                                                </VisualBrush.Visual>
                                            </VisualBrush>
                                        </Setter.Value>
                                    </Setter>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </TextBox.Resources>
                </TextBox>

                <Border Grid.Column="2"
                        Width="132"
                        Height="40"
                        CornerRadius="12"
                        Background="{StaticResource BackgroundTertiary}"
                        BorderBrush="{StaticResource BorderDefault}"
                        BorderThickness="1"
                        Padding="4"
                        VerticalAlignment="Center"
                        Margin="12,0,0,0">
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center">
                        <Button x:Name="OverlayKeywordSearchModeButton"
                                Content="Keyword"
                                Style="{StaticResource SearchModeButton}"
                                Click="KeywordSearchMode_Click"
                                ToolTip="Search filename, OCR text, and metadata"/>
                        <Button x:Name="OverlayAiSearchModeButton"
                                Content="AI"
                                Style="{StaticResource SearchModeButton}"
                                Margin="2,0,0,0"
                                Click="AiSearchMode_Click"
                                ToolTip="Use AI semantic search"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="3"
                        Height="40"
                        CornerRadius="12"
                        Background="{StaticResource BackgroundTertiary}"
                        BorderBrush="{StaticResource BorderDefault}"
                        BorderThickness="1"
                        Padding="12,0"
                        VerticalAlignment="Center"
                        Margin="12,0,0,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="Ctrl"
                                   Foreground="{StaticResource TextTertiary}"
                                   FontSize="11"
                                   FontWeight="700"/>
                        <TextBlock Text="+"
                                   Foreground="{StaticResource TextMuted}"
                                   FontSize="11"
                                   FontWeight="700"
                                   Margin="4,0"/>
                        <TextBlock Text="Shift"
                                   Foreground="{StaticResource TextTertiary}"
                                   FontSize="11"
                                   FontWeight="700"/>
                        <TextBlock Text="+"
                                   Foreground="{StaticResource TextMuted}"
                                   FontSize="11"
                                   FontWeight="700"
                                   Margin="4,0"/>
                        <TextBlock Text="Space"
                                   Foreground="{StaticResource AccentGlow}"
                                   FontSize="11"
                                   FontWeight="700"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="4"
                        Height="40"
                        Background="{StaticResource BackgroundTertiary}"
                        BorderBrush="{StaticResource BorderDefault}"
                        BorderThickness="1"
                        CornerRadius="12"
                        Padding="12,0"
                        VerticalAlignment="Center"
                        Margin="8,0,0,0">
                    <TextBlock Text="ESC"
                               Foreground="{StaticResource TextTertiary}"
                               FontSize="11"
                               FontWeight="700"
                               VerticalAlignment="Center"/>
                </Border>
            </Grid>

            <Border x:Name="Divider"
                    Grid.Row="1"
                    Height="1"
                    Background="{StaticResource BorderSubtle}"
                    Visibility="Collapsed"/>

            <ListBox x:Name="ResultsList"
                     Grid.Row="2"
                     Background="Transparent"
                     BorderThickness="0"
                     Foreground="{StaticResource TextPrimary}"
                     SelectionMode="Single"
                     Visibility="Collapsed"
                     Margin="12,8,12,12"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     VirtualizingStackPanel.IsVirtualizing="True"
                     VirtualizingStackPanel.VirtualizationMode="Recycling"
                     MouseDoubleClick="ResultsList_MouseDoubleClick">

                <ListBox.ItemsPanel>
                    <ItemsPanelTemplate>
                        <VirtualizingStackPanel/>
                    </ItemsPanelTemplate>
                </ListBox.ItemsPanel>

                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Padding" Value="0"/>
                        <Setter Property="Margin" Value="0,0,0,6"/>
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <Border x:Name="Bd"
                                            Background="Transparent"
                                            BorderBrush="Transparent"
                                            BorderThickness="1"
                                            CornerRadius="12"
                                            Padding="10,8">
                                        <ContentPresenter/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource BackgroundHover}"/>
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource AccentSubtle}"/>
                                            <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource AccentPrimary}"/>
                                            <Setter TargetName="Bd" Property="Effect" Value="{StaticResource AccentAura}"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListBox.ItemContainerStyle>

                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid VerticalAlignment="Center">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0"
                                    Width="88"
                                    Height="58"
                                    CornerRadius="10"
                                    Background="{StaticResource BackgroundPrimary}"
                                    ClipToBounds="True"
                                    BorderBrush="{StaticResource BorderSubtle}"
                                    BorderThickness="1">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding ThumbnailImage}" Value="{x:Null}">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <Image Source="{Binding ThumbnailImage}"
                                       Stretch="UniformToFill"
                                       RenderOptions.BitmapScalingMode="LowQuality"/>
                            </Border>

                            <Border Grid.Column="0"
                                    Width="88"
                                    Height="58"
                                    CornerRadius="10"
                                    Background="{StaticResource BackgroundPrimary}"
                                    BorderBrush="{StaticResource BorderSubtle}"
                                    BorderThickness="1">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding ThumbnailImage}" Value="{x:Null}">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <Viewbox Width="22" Height="22">
                                    <Path Data="M4 5h16v12H4V5zm2 2v8h12V7H6zm2 6l2.5-3 2 2.3L14 11l3 4H7l1-2z"
                                          Fill="{StaticResource BorderEmphasis}"
                                          Stretch="Uniform"/>
                                </Viewbox>
                            </Border>

                            <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                <TextBlock Text="{Binding FileName}"
                                           FontWeight="600"
                                           FontSize="12.5"
                                           Foreground="{StaticResource TextPrimary}"
                                           TextTrimming="CharacterEllipsis"/>
                                <TextBlock Text="{Binding CreatedAtLabel}"
                                           FontSize="10.5"
                                           Foreground="{StaticResource TextMuted}"
                                           Margin="0,3,0,0"/>
                                <TextBlock Text="{Binding MetadataLabel}"
                                           FontSize="10.5"
                                           Foreground="{StaticResource AccentGlow}"
                                           TextTrimming="CharacterEllipsis"
                                           Margin="0,3,0,0"/>
                            </StackPanel>

                            <StackPanel Grid.Column="3"
                                        Orientation="Horizontal"
                                        VerticalAlignment="Center"
                                        Margin="10,0,0,0">
                                <Button Content="Open"
                                        Style="{StaticResource ActionBtn}"
                                        Width="62"
                                        Height="30"
                                        Margin="0,0,6,0"
                                        Click="OpenButton_Click"/>
                                <Button Content="Reveal"
                                        Style="{StaticResource ActionBtn}"
                                        Width="70"
                                        Height="30"
                                        Click="RevealButton_Click"/>
                            </StackPanel>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Grid>
    </Border>
</Window>
