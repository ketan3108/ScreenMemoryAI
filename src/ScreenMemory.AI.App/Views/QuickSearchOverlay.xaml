<Window x:Class="ScreenMemory.AI.App.Views.QuickSearchOverlay"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Quick Search"
        Icon="pack://application:,,,/Assets/AppIcon.ico"
        Width="680"
        Height="100"
        MinHeight="100"
        MaxHeight="620"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        KeyDown="Window_KeyDown">

    <Window.Resources>

        <!-- Subtle scrollbar -->
        <Style x:Key="ThinScrollBar" TargetType="ScrollBar">
            <Setter Property="Width" Value="4"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Track x:Name="PART_Track" IsDirectionReversed="True">
                            <Track.Thumb>
                                <Thumb>
                                    <Thumb.Template>
                                        <ControlTemplate TargetType="Thumb">
                                            <Border Background="#3A4255" CornerRadius="2"/>
                                        </ControlTemplate>
                                    </Thumb.Template>
                                </Thumb>
                            </Track.Thumb>
                        </Track>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ThinScrollViewer" TargetType="ScrollViewer">
            <Setter Property="VerticalScrollBarVisibility" Value="Auto"/>
            <Setter Property="HorizontalScrollBarVisibility" Value="Disabled"/>
        </Style>

        <!-- Action buttons -->
        <Style x:Key="ActionBtn" TargetType="Button">
            <Setter Property="Foreground" Value="#8892A4"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="#252D3D"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontWeight" Value="Normal"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1E2535"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#3D4E6B"/>
                                <Setter Property="Foreground" Value="#C8D0E0"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#161C28"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Search TextBox style -->
        <Style x:Key="SearchBoxStyle" TargetType="TextBox">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#E8EDF5"/>
            <Setter Property="CaretBrush" Value="#6366F1"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <ScrollViewer x:Name="PART_ContentHost" Margin="0"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <!--
        Outer shell: dark frosted glass look.
        SizeToContent is NOT used — we control Height manually in code-behind
        to avoid WPF auto-layout adding blank space.
    -->
    <Border Background="#F0101520"
            BorderBrush="#222836"
            BorderThickness="1"
            CornerRadius="14"
            MouseLeftButtonDown="Shell_MouseLeftButtonDown"
            SnapsToDevicePixels="True">

        <Border.Effect>
            <DropShadowEffect Color="#000000" BlurRadius="32" ShadowDepth="8" Opacity="0.55"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>  <!-- search row -->
                <RowDefinition Height="Auto"/>  <!-- divider (only when results exist) -->
                <RowDefinition Height="Auto"/>  <!-- results list -->
            </Grid.RowDefinitions>

            <!-- ── Search row ──────────────────────────────────────────────── -->
            <Grid Grid.Row="0" Margin="14,10,14,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Search icon -->
                <Path Grid.Column="0"
                      Data="M11 3a8 8 0 1 0 0 16A8 8 0 0 0 11 3zm-9 8a9 9 0 1 1 15.32 6.41l4.14 4.13a1 1 0 0 1-1.42 1.42l-4.13-4.14A9 9 0 0 1 2 11z"
                      Fill="#4B5675"
                      Width="16" Height="16"
                      Stretch="Uniform"
                      VerticalAlignment="Center"
                      Margin="0,0,10,0"/>

                <TextBox x:Name="SearchBox"
                         Grid.Column="1"
                         Style="{StaticResource SearchBoxStyle}"
                         Height="36"
                         TextChanged="SearchBox_TextChanged">
                    <TextBox.Resources>
                        <!-- placeholder text -->
                        <Style TargetType="TextBox">
                            <Style.Triggers>
                                <Trigger Property="Text" Value="">
                                    <Setter Property="Background">
                                        <Setter.Value>
                                            <VisualBrush AlignmentX="Left" AlignmentY="Center" Stretch="None">
                                                <VisualBrush.Visual>
                                                    <TextBlock Text="Search screenshots…"
                                                               Foreground="#3D4760"
                                                               FontSize="15"
                                                               FontFamily="Segoe UI"
                                                               Margin="2,0,0,0"/>
                                                </VisualBrush.Visual>
                                            </VisualBrush>
                                        </Setter.Value>
                                    </Setter>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </TextBox.Resources>
                </TextBox>

                <!-- Esc hint -->
                <Border Grid.Column="2"
                        Background="#161C28"
                        BorderBrush="#252D3D"
                        BorderThickness="1"
                        CornerRadius="5"
                        Padding="7,3"
                        VerticalAlignment="Center"
                        Margin="10,0,0,0">
                    <TextBlock Text="ESC"
                               Foreground="#3D4760"
                               FontSize="10"
                               FontFamily="Segoe UI"
                               FontWeight="SemiBold"/>
                </Border>
            </Grid>

            <!-- ── Divider (only visible when results list is visible) ──────── -->
            <Border x:Name="Divider"
                    Grid.Row="1"
                    Height="1"
                    Background="#1A2030"
                    Margin="0"
                    Visibility="Collapsed"/>

            <!-- ── Results list ───────────────────────────────────────────────
                 VirtualizingStackPanel so only visible rows are rendered.
            ── -->
            <ListBox x:Name="ResultsList"
                     Grid.Row="2"
                     Background="Transparent"
                     BorderThickness="0"
                     Foreground="#E0E6F0"
                     SelectionMode="Single"
                     Visibility="Collapsed"
                     Margin="8,6,8,8"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     VirtualizingStackPanel.IsVirtualizing="True"
                     VirtualizingStackPanel.VirtualizationMode="Recycling"
                     MouseDoubleClick="ResultsList_MouseDoubleClick">

                <ListBox.ItemsPanel>
                    <ItemsPanelTemplate>
                        <VirtualizingStackPanel/>
                    </ItemsPanelTemplate>
                </ListBox.ItemsPanel>

                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Padding" Value="0"/>
                        <Setter Property="Margin" Value="0,0,0,4"/>
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <Border x:Name="Bd"
                                            Background="Transparent"
                                            BorderBrush="Transparent"
                                            BorderThickness="1"
                                            CornerRadius="9"
                                            Padding="8,7">
                                        <ContentPresenter/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="#12181F"/>
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="#141B2A"/>
                                            <Setter TargetName="Bd" Property="BorderBrush" Value="#2C3A5C"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListBox.ItemContainerStyle>

                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid VerticalAlignment="Center">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <!-- Thumbnail -->
                            <Border Grid.Column="0"
                                    Width="78"
                                    Height="52"
                                    CornerRadius="7"
                                    Background="#0D1018"
                                    ClipToBounds="True">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding ThumbnailImage}" Value="{x:Null}">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <Image Source="{Binding ThumbnailImage}"
                                       Stretch="UniformToFill"
                                       RenderOptions.BitmapScalingMode="LowQuality"/>
                            </Border>

                            <!-- No-thumbnail placeholder -->
                            <Border Grid.Column="0"
                                    Width="78"
                                    Height="52"
                                    CornerRadius="7"
                                    Background="#0D1018">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding ThumbnailImage}" Value="{x:Null}">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <Path Data="M4 4h16v12H4z M8 10l3 3 4-5 5 6H4z"
                                      Fill="#1E2535"
                                      Width="20" Height="20"
                                      Stretch="Uniform"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center"/>
                            </Border>

                            <!-- File info -->
                            <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                <TextBlock Text="{Binding FileName}"
                                           FontWeight="Medium"
                                           FontSize="12.5"
                                           FontFamily="Segoe UI"
                                           Foreground="#C8D4E8"
                                           TextTrimming="CharacterEllipsis"/>
                                <TextBlock Text="{Binding CreatedAtLabel}"
                                           FontSize="10"
                                           FontFamily="Segoe UI"
                                           Foreground="#3D4760"
                                           Margin="0,3,0,0"/>
                            </StackPanel>

                            <!-- Action buttons -->
                            <StackPanel Grid.Column="3"
                                        Orientation="Horizontal"
                                        VerticalAlignment="Center"
                                        Margin="8,0,0,0">
                                <Button Content="Open"
                                        Style="{StaticResource ActionBtn}"
                                        Width="58" Height="28"
                                        Margin="0,0,5,0"
                                        Click="OpenButton_Click"/>
                                <Button Content="Reveal"
                                        Style="{StaticResource ActionBtn}"
                                        Width="62" Height="28"
                                        Click="RevealButton_Click"/>
                            </StackPanel>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Grid>
    </Border>
</Window>
