<Window x:Class="ScreenMemory.AI.App.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Settings - ScreenMemory"
        Width="680"
        Height="560"
        MinWidth="580"
        MinHeight="480"
        WindowStartupLocation="CenterOwner"
        FontFamily="Segoe UI Variable Display, Segoe UI Variable, Segoe UI, sans-serif"
        Background="#0B0B0D"
        ResizeMode="NoResize"
        WindowStyle="None">

    <Window.Resources>

        <!-- ═══════════════════════════════════════════════════════
             SOPHISTICATED COLOR PALETTE
        ═══════════════════════════════════════════════════════ -->
        
        <!-- Core Backgrounds -->
        <SolidColorBrush x:Key="BackgroundDeep"       Color="#070708"/>
        <SolidColorBrush x:Key="BackgroundPrimary"    Color="#0B0B0D"/>
        <SolidColorBrush x:Key="BackgroundSecondary"  Color="#111217"/>
        <SolidColorBrush x:Key="BackgroundTertiary"   Color="#18191F"/>
        <SolidColorBrush x:Key="BackgroundElevated"   Color="#1F2129"/>
        <SolidColorBrush x:Key="BackgroundHover"      Color="#252833"/>
        
        <!-- Glass Effect -->
        <SolidColorBrush x:Key="GlassBackground"     Color="#12131A"/>
        <SolidColorBrush x:Key="GlassBorder"         Color="#2A2D3A"/>
        
        <!-- Borders -->
        <SolidColorBrush x:Key="BorderSubtle"        Color="#1A1C25"/>
        <SolidColorBrush x:Key="BorderDefault"       Color="#252A38"/>
        <SolidColorBrush x:Key="BorderEmphasis"       Color="#3D4459"/>
        
        <!-- Neon Purple Accent System -->
        <SolidColorBrush x:Key="AccentPrimary"        Color="#8B5CF6"/>
        <SolidColorBrush x:Key="AccentHover"          Color="#A78BFA"/>
        <SolidColorBrush x:Key="AccentPressed"        Color="#7C3AED"/>
        <SolidColorBrush x:Key="AccentSubtle"         Color="#1E1832"/>
        <SolidColorBrush x:Key="AccentMuted"          Color="#5B4A8C"/>
        <SolidColorBrush x:Key="AccentGlow"           Color="#C4B5FD"/>
        <SolidColorBrush x:Key="AccentGlowIntense"    Color="#DDD6FE"/>
        
        <!-- Gradient for Glow Effects -->
        <LinearGradientBrush x:Key="AccentGlowGradient" StartPoint="0,0" EndPoint="1,0">
            <GradientStop Color="#8B5CF6" Offset="0"/>
            <GradientStop Color="#A78BFA" Offset="1"/>
        </LinearGradientBrush>
        
        <LinearGradientBrush x:Key="AccentVerticalGlow" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#8B5CF6" Offset="0"/>
            <GradientStop Color="#6366F1" Offset="1"/>
        </LinearGradientBrush>
        
        <!-- Status Colors -->
        <SolidColorBrush x:Key="StatusSuccess"        Color="#10B981"/>
        <SolidColorBrush x:Key="StatusSuccessGlow"    Color="#34D399"/>
        <SolidColorBrush x:Key="StatusSuccessSubtle"  Color="#0D2E22"/>
        <SolidColorBrush x:Key="StatusWarning"         Color="#F59E0B"/>
        <SolidColorBrush x:Key="StatusError"          Color="#EF4444"/>
        <SolidColorBrush x:Key="StatusErrorSubtle"    Color="#2D1515"/>
        <SolidColorBrush x:Key="StatusInfo"           Color="#3B82F6"/>
        
        <!-- Text Colors -->
        <SolidColorBrush x:Key="TextPrimary"          Color="#FAFAFA"/>
        <SolidColorBrush x:Key="TextSecondary"        Color="#A1A7B3"/>
        <SolidColorBrush x:Key="TextTertiary"        Color="#6B7280"/>
        <SolidColorBrush x:Key="TextMuted"            Color="#4B5563"/>

        <!-- ═══════════════════════════════════════════════════════
             DROP SHADOW EFFECTS
        ═══════════════════════════════════════════════════════ -->
        
        <DropShadowEffect x:Key="NeonGlowShadow"
                          Color="#8B5CF6"
                          BlurRadius="20"
                          ShadowDepth="0"
                          Opacity="0.4"/>
        
        <DropShadowEffect x:Key="CardShadow"
                          Color="#000000"
                          BlurRadius="24"
                          ShadowDepth="4"
                          Opacity="0.5"/>
        
        <DropShadowEffect x:Key="ModalShadow"
                          Color="#000000"
                          BlurRadius="40"
                          ShadowDepth="8"
                          Opacity="0.6"/>
        
        <DropShadowEffect x:Key="SubtleShadow"
                          Color="#000000"
                          BlurRadius="12"
                          ShadowDepth="2"
                          Opacity="0.3"/>

        <!-- ═══════════════════════════════════════════════════════
             TYPOGRAPHY
        ═══════════════════════════════════════════════════════ -->
        
        <Style x:Key="TypographyTitleLarge" TargetType="TextBlock">
            <Setter Property="FontSize" Value="22"/>
            <Setter Property="FontWeight" Value="600"/>
            <Setter Property="FontFamily" Value="Segoe UI Variable Display, Segoe UI, sans-serif"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
        </Style>
        
        <Style x:Key="TypographyTitleMedium" TargetType="TextBlock">
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="600"/>
            <Setter Property="FontFamily" Value="Segoe UI Variable Display, Segoe UI, sans-serif"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
        </Style>
        
        <Style x:Key="TypographyTitleSmall" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="600"/>
            <Setter Property="FontFamily" Value="Segoe UI Variable Display, Segoe UI, sans-serif"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
        </Style>
        
        <Style x:Key="TypographyBodyLarge" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="400"/>
            <Setter Property="FontFamily" Value="Segoe UI Variable Display, Segoe UI, sans-serif"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
            <Setter Property="LineHeight" Value="20"/>
        </Style>
        
        <Style x:Key="TypographyBodyDefault" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="400"/>
            <Setter Property="FontFamily" Value="Segoe UI Variable Display, Segoe UI, sans-serif"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
        </Style>
        
        <Style x:Key="TypographyBodySmall" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="400"/>
            <Setter Property="FontFamily" Value="Segoe UI Variable Display, Segoe UI, sans-serif"/>
            <Setter Property="Foreground" Value="{StaticResource TextTertiary}"/>
        </Style>
        
        <Style x:Key="TypographyLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="FontWeight" Value="600"/>
            <Setter Property="FontFamily" Value="Segoe UI Variable Display, Segoe UI, sans-serif"/>
            <Setter Property="Foreground" Value="{StaticResource TextMuted}"/>
        </Style>

        <!-- ═══════════════════════════════════════════════════════
             BUTTON STYLES
        ═══════════════════════════════════════════════════════ -->

        <Style x:Key="ButtonPrimary" TargetType="Button">
            <Setter Property="Background">
                <Setter.Value>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#8B5CF6" Offset="0"/>
                        <GradientStop Color="#7C3AED" Offset="1"/>
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="600"/>
            <Setter Property="FontFamily" Value="Segoe UI Variable Display, Segoe UI, sans-serif"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}"
                                Effect="{StaticResource NeonGlowShadow}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background">
                                    <Setter.Value>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#A78BFA" Offset="0"/>
                                            <GradientStop Color="#8B5CF6" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Setter.Value>
                                </Setter>
                                <Setter TargetName="border" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect Color="#A78BFA" BlurRadius="30" ShadowDepth="0" Opacity="0.6"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background">
                                    <Setter.Value>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#7C3AED" Offset="0"/>
                                            <GradientStop Color="#6D28D9" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Opacity" Value="0.5"/>
                                <Setter TargetName="border" Property="Effect" Value="{x:Null}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ButtonSecondary" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource BackgroundElevated}"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderDefault}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="500"/>
            <Setter Property="FontFamily" Value="Segoe UI Variable Display, Segoe UI, sans-serif"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="14,9"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{StaticResource BackgroundHover}"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource BorderEmphasis}"/>
                                <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{StaticResource BackgroundTertiary}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ButtonGhost" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TextTertiary}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="500"/>
            <Setter Property="FontFamily" Value="Segoe UI Variable Display, Segoe UI, sans-serif"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{StaticResource BackgroundTertiary}"/>
                                <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{StaticResource BackgroundSecondary}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ButtonIcon" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TextTertiary}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="32"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets, Segoe UI Symbol, sans-serif"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{StaticResource BackgroundHover}"/>
                                <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{StaticResource BackgroundTertiary}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ButtonClose" TargetType="Button" BasedOn="{StaticResource ButtonIcon}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#DC2626"/>
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#B91C1C"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══════════════════════════════════════════════════════
             FOLDER LIST ITEM STYLE
        ═══════════════════════════════════════════════════════ -->

        <Style x:Key="FolderListItem" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Bd"
                                Background="{StaticResource BackgroundTertiary}"
                                BorderBrush="{StaticResource BorderSubtle}"
                                BorderThickness="1"
                                CornerRadius="10"
                                Padding="14,12">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                
                                <!-- Glow Accent Bar -->
                                <Border Grid.Column="0" 
                                        Width="4" Height="36" 
                                        CornerRadius="2"
                                        Background="{StaticResource AccentPrimary}"
                                        Margin="0,0,14,0"
                                        Opacity="0.6">
                                    <Border.Effect>
                                        <DropShadowEffect Color="#8B5CF6" BlurRadius="8" ShadowDepth="0" Opacity="0.5"/>
                                    </Border.Effect>
                                </Border>
                                
                                <!-- Folder Icon -->
                                <Border Grid.Column="1" 
                                        Width="38" Height="38" 
                                        CornerRadius="10"
                                        Background="{StaticResource BackgroundSecondary}"
                                        BorderBrush="{StaticResource BorderDefault}"
                                        BorderThickness="1"
                                        VerticalAlignment="Center">
                                    <Viewbox Width="18" Height="18">
                                        <Path Data="M20 6h-8l-2-2H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V8c0-1.1-.9-2-2-2zm0 12H4V6h5.17l2 2H20v10z" 
                                              Fill="{StaticResource AccentGlow}" Stretch="Uniform"/>
                                    </Viewbox>
                                </Border>
                                
                                <!-- Folder Path -->
                                <StackPanel Grid.Column="2" Margin="12,0,0,0" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding}"
                                               FontSize="12.5"
                                               FontWeight="500"
                                               Foreground="{StaticResource TextPrimary}"
                                               TextTrimming="CharacterEllipsis"
                                               ToolTip="{Binding}"/>
                                </StackPanel>
                                
                                <!-- Remove Button -->
                                <Button Grid.Column="3"
                                        Content="&#xE711;"
                                        Style="{StaticResource ButtonIcon}"
                                        Width="28" Height="28"
                                        FontSize="10"
                                        ToolTip="Remove folder"
                                        Tag="{Binding}"
                                        Click="RemoveFolderItem_Click"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource BackgroundElevated}"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource BorderDefault}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource AccentSubtle}"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource AccentPrimary}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══════════════════════════════════════════════════════
             SCROLLBAR STYLE
        ═══════════════════════════════════════════════════════ -->
        
        <Style TargetType="ScrollBar">
            <Setter Property="Width" Value="6"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid>
                            <Track x:Name="PART_Track" IsDirectionReversed="True">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Opacity="0" Height="0"/>
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border Background="{StaticResource BorderDefault}" CornerRadius="3" Margin="1"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Opacity="0" Height="0"/>
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <!-- Main Container with Glass Effect -->
    <Border Background="{StaticResource GlassBackground}"
            BorderBrush="{StaticResource GlassBorder}"
            BorderThickness="1"
            CornerRadius="16"
            Effect="{StaticResource ModalShadow}">
        
        <Grid Background="{StaticResource BackgroundPrimary}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- ╔════════════════════════════════════════════════════╗
                 ║                    HEADER                        ║
                 ╚════════════════════════════════════════════════════╝ -->
            <Border Grid.Row="0"
                    Background="Transparent"
                    BorderBrush="{StaticResource BorderSubtle}"
                    BorderThickness="0,0,0,1"
                    Padding="20,16"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                        <!-- App Icon with Glow -->
                        <Border Width="40" Height="40" CornerRadius="12" ClipToBounds="True"
                                Background="{StaticResource BackgroundTertiary}"
                                BorderBrush="{StaticResource AccentPrimary}"
                                BorderThickness="1.5">
                            <Border.Effect>
                                <DropShadowEffect Color="#8B5CF6" BlurRadius="12" ShadowDepth="0" Opacity="0.4"/>
                            </Border.Effect>
                            <Image Source="pack://application:,,,/Assets/AppIcon.ico" 
                                   Stretch="UniformToFill" 
                                   Margin="8"/>
                        </Border>
                        
                        <StackPanel Margin="16,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="Settings"
                                       Style="{StaticResource TypographyTitleLarge}"/>
                            <TextBlock Text="Configure your screenshot workspace"
                                       Style="{StaticResource TypographyBodySmall}"
                                       Margin="0,3,0,0"/>
                        </StackPanel>
                    </StackPanel>
                    
                    <Button Grid.Column="1"
                            Content="&#xE8BB;"
                            Style="{StaticResource ButtonClose}"
                            Click="Close_Click"
                            ToolTip="Close"/>
                </Grid>
            </Border>

            <!-- ╔════════════════════════════════════════════════════╗
                 ║                 CONTENT AREA                    ║
                 ╚════════════════════════════════════════════════════╝ -->
            <ScrollViewer Grid.Row="1" 
                          VerticalScrollBarVisibility="Auto" 
                          Padding="20,18">
                <StackPanel>

                    <!-- Watched Folders Section -->
                    <Border Background="{StaticResource BackgroundTertiary}"
                            BorderBrush="{StaticResource BorderSubtle}"
                            BorderThickness="1"
                            CornerRadius="14"
                            Padding="20"
                            Effect="{StaticResource SubtleShadow}">
                        <StackPanel>
                        
                            <!-- Section Header -->
                            <Grid Margin="0,0,0,16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                
                                <StackPanel Grid.Column="0">
                                    <StackPanel Orientation="Horizontal">
                                        <Border Width="8" Height="8" CornerRadius="4" 
                                                Background="{StaticResource AccentPrimary}"
                                                Margin="0,0,10,0" VerticalAlignment="Center">
                                            <Border.Effect>
                                                <DropShadowEffect Color="#8B5CF6" BlurRadius="6" ShadowDepth="0" Opacity="0.6"/>
                                            </Border.Effect>
                                        </Border>
                                        <TextBlock Text="Watched Folders"
                                                   Style="{StaticResource TypographyTitleMedium}"/>
                                    </StackPanel>
                                    <TextBlock Text="Screenshots in these folders are indexed automatically."
                                               Style="{StaticResource TypographyBodySmall}"
                                               Margin="18,4,0,0"/>
                                </StackPanel>
                                
                                <Button Grid.Column="1"
                                        x:Name="AddFolderBtn"
                                        Style="{StaticResource ButtonSecondary}"
                                        Click="AddFolder_Click"
                                        VerticalAlignment="Center">
                                    <StackPanel Orientation="Horizontal">
                                        <Viewbox Width="14" Height="14" Margin="0,0,8,0">
                                            <Path Data="M19 13h-6v6h-2v-6H5v-2h6V5h2v6h6v2z" 
                                                  Fill="{StaticResource AccentGlow}" Stretch="Uniform"/>
                                        </Viewbox>
                                        <TextBlock Text="Add Folder" FontWeight="600"/>
                                    </StackPanel>
                                </Button>
                            </Grid>

                            <!-- Empty State -->
                            <Border x:Name="EmptyState"
                                    Background="{StaticResource BackgroundSecondary}"
                                    BorderBrush="{StaticResource BorderSubtle}"
                                    BorderThickness="1"
                                    CornerRadius="12"
                                    Padding="32,28">
                                <StackPanel HorizontalAlignment="Center">
                                    <Border Width="56" Height="56" CornerRadius="16"
                                            Background="{StaticResource BackgroundTertiary}"
                                            BorderBrush="{StaticResource BorderDefault}"
                                            BorderThickness="1"
                                            Margin="0,0,0,16">
                                        <Viewbox Width="24" Height="24">
                                            <Path Data="M20 6h-8l-2-2H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V8c0-1.1-.9-2-2-2zm0 12H4V6h5.17l2 2H20v10zm-2-6H6v-2h12v2zm0-4H6V8h12v2z" 
                                                  Fill="{StaticResource TextMuted}" Stretch="Uniform"/>
                                        </Viewbox>
                                    </Border>
                                    <TextBlock Text="No folders added yet"
                                              FontSize="14"
                                              FontWeight="600"
                                              Foreground="{StaticResource TextSecondary}"
                                              HorizontalAlignment="Center"/>
                                    <TextBlock Text="Click 'Add Folder' to select your screenshot location."
                                               Style="{StaticResource TypographyBodySmall}"
                                               HorizontalAlignment="Center"
                                               Margin="0,6,0,0"/>
                                </StackPanel>
                            </Border>

                            <!-- Folders List -->
                            <ListBox x:Name="FoldersList"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     ItemContainerStyle="{StaticResource FolderListItem}"
                                     MinHeight="70"
                                     MaxHeight="280"
                                     Visibility="Collapsed"
                                     SelectionChanged="FoldersList_SelectionChanged"/>

                        </StackPanel>
                    </Border>

                    <!-- Privacy Info Banner with Glow Border -->
                    <Border Background="{StaticResource BackgroundSecondary}"
                            BorderBrush="{StaticResource AccentPrimary}"
                            BorderThickness="1"
                            CornerRadius="12"
                            Padding="16,14"
                            Margin="0,16,0,0">
                        <Border.Effect>
                            <DropShadowEffect Color="#8B5CF6" BlurRadius="15" ShadowDepth="0" Opacity="0.15"/>
                        </Border.Effect>
                        <StackPanel Orientation="Horizontal">
                            <Border Width="36" Height="36" CornerRadius="10"
                                    Background="{StaticResource AccentSubtle}"
                                    Margin="0,0,14,0">
                                <Viewbox Width="18" Height="18">
