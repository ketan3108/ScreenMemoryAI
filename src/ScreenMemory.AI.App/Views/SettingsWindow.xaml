<Window x:Class="ScreenMemory.AI.App.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Settings - ScreenMemory"
        Width="740"
        Height="430"
        MinWidth="620"
        MinHeight="400"
        WindowStartupLocation="CenterOwner"
        FontFamily="Segoe UI Variable Display, Segoe UI, sans-serif"
        Background="#0D0F14"
        ResizeMode="NoResize"
        WindowStyle="None">

    <Window.Resources>
        <SolidColorBrush x:Key="BgBase" Color="#0D0F14"/>
        <SolidColorBrush x:Key="BgSurface" Color="#13161D"/>
        <SolidColorBrush x:Key="BgCard" Color="#181C25"/>
        <SolidColorBrush x:Key="BorderSubtle" Color="#1F2533"/>
        <SolidColorBrush x:Key="BorderMed" Color="#293044"/>
        <SolidColorBrush x:Key="AccentPrimary" Color="#6366F1"/>
        <SolidColorBrush x:Key="TextPrimary" Color="#F0F2F8"/>
        <SolidColorBrush x:Key="TextSecondary" Color="#8892A4"/>
        <SolidColorBrush x:Key="TextMuted" Color="#4A5568"/>

        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#6366F1"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#7577F3"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#4F51C8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="GhostButton" TargetType="Button">
            <Setter Property="Background" Value="#1A1F2E"/>
            <Setter Property="Foreground" Value="#8892A4"/>
            <Setter Property="BorderBrush" Value="#1F2533"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="FontSize" Value="12.5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1E2330"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#293044"/>
                                <Setter Property="Foreground" Value="#C8CFDD"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1A1F35"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DangerButton" TargetType="Button" BasedOn="{StaticResource GhostButton}">
            <Setter Property="Foreground" Value="#F87171"/>
            <Setter Property="BorderBrush" Value="#7F1D1D"/>
            <Setter Property="Background" Value="#1F1316"/>
        </Style>

        <Style x:Key="FolderListItem" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
            <Setter Property="Background" Value="#151A23"/>
            <Setter Property="Foreground" Value="#D1D7E3"/>
            <Setter Property="BorderBrush" Value="#1F2533"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="📁" Margin="0,0,10,0" VerticalAlignment="Center" FontSize="13"/>
                                <ContentPresenter Grid.Column="1" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1A2030"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#293044"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1C203A"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#6366F1"/>
                                <Setter Property="Foreground" Value="#A5B4FC"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Background="{StaticResource BgBase}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{StaticResource BgSurface}"
                BorderBrush="{StaticResource BorderSubtle}"
                BorderThickness="0,0,0,1"
                Padding="16,12"
                MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal">
                    <Border Width="28" Height="28" CornerRadius="7" ClipToBounds="True" VerticalAlignment="Center">
                        <Image Source="pack://application:,,,/Assets/AppIcon.ico" Stretch="UniformToFill"/>
                    </Border>
                    <StackPanel Margin="10,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="Settings"
                                   FontSize="17"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimary}"/>
                        <TextBlock Text="Manage folders for indexing."
                                   FontSize="11.5"
                                   Foreground="{StaticResource TextSecondary}"/>
                    </StackPanel>
                </StackPanel>
                <Button Grid.Column="1"
                        Content="✕"
                        Width="32"
                        Height="28"
                        Style="{StaticResource GhostButton}"
                        Padding="0"
                        Click="Close_Click"/>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="16,12,16,0">
            <StackPanel>
                <Border Background="{StaticResource BgCard}"
                        BorderBrush="{StaticResource BorderSubtle}"
                        BorderThickness="1"
                        CornerRadius="12"
                        Padding="14">
                    <StackPanel>
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Watched Folders"
                                           FontSize="14.5"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource TextPrimary}"/>
                                <TextBlock Text="Screenshots in these folders are indexed automatically."
                                           FontSize="11.5"
                                           Foreground="{StaticResource TextMuted}"
                                           Margin="0,2,0,0"/>
                            </StackPanel>
                            <Button Grid.Column="1"
                                    x:Name="AddFolderBtn"
                                    Content="+ Add Folder"
                                    Style="{StaticResource PrimaryButton}"
                                    Padding="16,0"
                                    Click="AddFolder_Click"
                                    VerticalAlignment="Center"/>
                        </Grid>

                        <Border x:Name="EmptyState"
                                Background="#141924"
                                BorderBrush="{StaticResource BorderSubtle}"
                                BorderThickness="1"
                                CornerRadius="10"
                                Padding="18,24">
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock Text="No folders added yet"
                                           FontSize="14"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource TextSecondary}"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="Click Add Folder to select your screenshot location."
                                           FontSize="12"
                                           Foreground="{StaticResource TextMuted}"
                                           HorizontalAlignment="Center"
                                           Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>

                        <ListBox x:Name="FoldersList"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 ItemContainerStyle="{StaticResource FolderListItem}"
                                 MinHeight="40"
                                 MaxHeight="180"
                                 Visibility="Collapsed"/>

                        <Border Margin="0,12,0,0"
                                Visibility="{Binding Visibility, ElementName=FoldersList}">
                            <Button x:Name="RemoveFolderBtn"
                                    Content="Remove Selected"
                                    Style="{StaticResource DangerButton}"
                                    Padding="16,0"
                                    HorizontalAlignment="Left"
                                    Click="RemoveFolder_Click"/>
                        </Border>
                    </StackPanel>
                </Border>

                <Border Background="#141D2E"
                        BorderBrush="#24334C"
                        BorderThickness="1"
                        CornerRadius="10"
                        Padding="14,11"
                        Margin="0,10,0,0">
                    <TextBlock Text="All indexing runs locally on your device."
                               FontSize="12"
                               Foreground="#9AB2D6"/>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <Border Grid.Row="2"
                Background="{StaticResource BgSurface}"
                BorderBrush="{StaticResource BorderSubtle}"
                BorderThickness="0,1,0,0"
                Padding="16,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="Changes are saved automatically."
                           FontSize="12"
                           Foreground="{StaticResource TextMuted}"
                           VerticalAlignment="Center"/>

                <Button Grid.Column="1"
                        Content="Close"
                        Style="{StaticResource GhostButton}"
                        Padding="20,0"
                        Click="Close_Click"/>
            </Grid>
        </Border>
    </Grid>
</Window>
